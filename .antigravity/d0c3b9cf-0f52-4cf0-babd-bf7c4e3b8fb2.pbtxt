  file_change {
    absolute_path_uri: "file:///server.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express from \"express\";\nimport path from \"path\";\nimport dotenv from \"dotenv\";\nimport { GoogleGenAI } from \"@google/genai\";\nimport { createServer as createViteServer } from \"vite\";\n\ndotenv.config();\n\nconst app = express();\nconst PORT = 3000;\n\napp.use(express.json());\n\n// Lazy-initialized Gemini AI client to prevent startup crashes when key is missing\nlet aiClient: GoogleGenAI | null = null;\n\nfunction getGeminiClient(): GoogleGenAI {\n  if (!aiClient) {\n    const apiKey = process.env.GEMINI_API_KEY;\n    if (!apiKey) {\n      throw new Error(\"GEMINI_API_KEY is not defined in environment variables.\");\n    }\n    aiClient = new GoogleGenAI({\n      apiKey,\n      httpOptions: {\n        headers: {\n          \'User-Agent\': \'aistudio-build\',\n        }\n      }\n    });\n  }\n  return aiClient;\n}\n\n// API endpoint for luxury designer stylist chat\napp.post(\"/api/stylist/chat\", async (req, res) => {\n  try {\n    const { message, currentDesign } = req.body;\n    \n    // Check if the API key is missing or set to the default placeholder in .env.example\n    const apiKey = process.env.GEMINI_API_KEY;\n    const isKeyUnconfigured = !apiKey || apiKey === \"MY_GEMINI_API_KEY\" || apiKey.trim() === \"\";\n\n    if (isKeyUnconfigured) {\n      // Return a beautifully crafted fallback response mimicking high-end French luxury tone\n      let fallbackText = \"Estimado cliente, los astros y los metales m\303\241s nobles se alinean hoy en nuestro taller. \";\n      if (currentDesign) {\n        fallbackText += `He contemplado con absoluta admiraci\303\263n su dise\303\261o en el simulador: una magn\303\255fica creaci\303\263n de tipo ${currentDesign.type}, forjada en el m\303\241s puro ${currentDesign.metal}, engastada con un celestial ${currentDesign.gemstone} tallado en corte ${currentDesign.cut}. La combinaci\303\263n es un testimonio de su gusto exquisito. El fulgor de la gema evoca promesas eternas, mientras que el metal noble ancla su brillo en la inmortalidad. `;\n      } else {\n        fallbackText += \"Bienvenidos a nuestro santuario de alta orfebrer\303\255a. Cada diamante y cada filamento de oro aguardan silenciosamente para convertirse en parte de su propia leyenda. \";\n      }\n      fallbackText += \"Le recomiendo lucir esta excepcional pieza con prendas de sat\303\251n oscuro o terciopelo negro profundo, permitiendo que la refracci\303\263n de la luz capture la atenci\303\263n de cualquier sal\303\263n. \302\277Desea que exploremos alg\303\272n otro detalle en la montura o la selecci\303\263n de gemas secundarias?\";\n      \n      return res.json({ text: fallbackText, isFallback: true });\n    }\n\n    const client = getGeminiClient();\n    \n    let designContext = \"\";\n    if (currentDesign) {\n      designContext = `\\n[Contexto del dise\303\261o actual creado por el cliente: Tipo de joya: ${currentDesign.type}, Metal noble: ${currentDesign.metal}, Gema preciosa: ${currentDesign.gemstone}, Talla de la gema: ${currentDesign.cut}].`;\n    }\n\n    const contents = [\n      {\n        role: \"user\",\n        parts: [{ text: `${message}${designContext}` }]\n      }\n    ];\n\n    const response = await client.models.generateContent({\n      model: \"gemini-3.5-flash\",\n      contents,\n      config: {\n        systemInstruction: \"Eres \'Aurelia\', la prestigiosa maestra joyera y guardiana del dise\303\261o de la legendaria Maison \'AURA Joyer\303\255a\'. Tu tono es sumamente refinado, po\303\251tico, sofisticado y exclusivo, similar al de las m\303\241s respetadas casas de alta joyer\303\255a de la Place Vend\303\264me de Par\303\255s. Te expresas de manera elocuente, \303\255ntima y distinguida en espa\303\261ol. Utilizas un vocabulario exquisito con t\303\251rminos como \'orfebrer\303\255a\', \'talla de precisi\303\263n\', \'montura sublime\', \'destello celestial\', \'refracci\303\263n de luz\', \'metal noble\'. Ofreces historias simb\303\263licas sobre las piedras elegidas, sugieres combinaciones est\303\251ticas perfectas para galas y vestidos, y validas el gusto del cliente. Mant\303\251n las respuestas elegantes y memorables, entre 120 y 180 palabras para mantener el misterio y la distinci\303\263n de una verdadera orfebre.\",\n        temperature: 0.95,\n      }\n    });\n\n    res.json({ text: response.text });\n  } catch (error: any) {\n    console.error(\"Gemini API error:\", error);\n    res.status(500).json({ error: error.message || \"Error al conectar con la maestra joyera.\" });\n  }\n});\n\n// Setup Vite Dev server middleware or static serving\nasync function bootstrap() {\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \'dist\');\n    app.use(express.static(distPath));\n    app.get(\'*\', (req, res) => {\n      res.sendFile(path.join(distPath, \'index.html\'));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(`Luxury Jewelry Dev Server running on http://localhost:${PORT}`);\n  });\n}\n\nbootstrap();\n"
    }
