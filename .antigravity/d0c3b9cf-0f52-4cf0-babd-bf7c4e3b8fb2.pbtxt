    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useEffect, useRef } from \'react\';\nimport { \n  Sparkles, \n  Clock, \n  Compass, \n  ShieldCheck, \n  Award, \n  Menu, \n  X, \n  MessageSquare, \n  ShoppingBag, \n  Eye, \n  ChevronDown,\n  Hammer\n} from \'lucide-react\';\nimport { CustomJewelryDesign, CollectionItem } from \'./types\';\nimport AtelierCustomizer from \'./components/AtelierCustomizer\';\nimport CollectionGrid from \'./components/CollectionGrid\';\nimport AIStylist from \'./components/AIStylist\';\nimport { motion, AnimatePresence } from \'motion/react\';\n\nexport default function App() {\n  const [activeDesign, setActiveDesign] = useState<CustomJewelryDesign | null>(null);\n  const [isStylistOpen, setIsStylistOpen] = useState(false);\n  const [time, setTime] = useState<string>(\'\');\n  const [activeCity, setActiveCity] = useState<\'Par\303\255s\' | \'Ginebra\' | \'Tokio\'>(\'Par\303\255s\');\n  const [scrolled, setScrolled] = useState(false);\n  const canvasRef = useRef<HTMLCanvasElement | null>(null);\n\n  // Timezones for luxury centers\n  useEffect(() => {\n    const updateClock = () => {\n      const now = new Date();\n      let options: Intl.DateTimeFormatOptions = {\n        hour: \'2-digit\',\n        minute: \'2-digit\',\n        second: \'2-digit\',\n        hour12: false,\n      };\n\n      if (activeCity === \'Par\303\255s\') {\n        options.timeZone = \'Europe/Paris\';\n      } else if (activeCity === \'Ginebra\') {\n        options.timeZone = \'Europe/Zurich\';\n      } else {\n        options.timeZone = \'Asia/Tokyo\';\n      }\n\n      setTime(new Intl.DateTimeFormat(\'es-ES\', options).format(now));\n    };\n\n    updateClock();\n    const interval = setInterval(updateClock, 1000);\n    return () => clearInterval(interval);\n  }, [activeCity]);\n\n  // Handle header scroll transparency\n  useEffect(() => {\n    const handleScroll = () => {\n      if (window.scrollY > 50) {\n        setScrolled(true);\n      } else {\n        setScrolled(false);\n      }\n    };\n    window.addEventListener(\'scroll\', handleScroll);\n    return () => window.removeEventListener(\'scroll\', handleScroll);\n  }, []);\n\n  // HTML5 Canvas Golden Dust Particle Animation (Adaptive sizing)\n  useEffect(() => {\n    const canvas = canvasRef.current;\n    if (!canvas) return;\n\n    const ctx = canvas.getContext(\'2d\');\n    if (!ctx) return;\n\n    let animationFrameId: number;\n    let width = canvas.width = canvas.offsetWidth;\n    let height = canvas.height = canvas.offsetHeight;\n\n    // Handle Resize using ResizeObserver as requested\n    const resizeObserver = new ResizeObserver((entries) => {\n      for (const entry of entries) {\n        width = canvas.width = entry.contentRect.width;\n        height = canvas.height = entry.contentRect.height;\n      }\n    });\n    \n    // Parent element observe\n    if (canvas.parentElement) {\n      resizeObserver.observe(canvas.parentElement);\n    }\n\n    // Particle class\n    class Particle {\n      x: number;\n      y: number;\n      size: number;\n      speedX: number;\n      speedY: number;\n      opacity: number;\n      opacitySpeed: number;\n\n      constructor() {\n        this.x = Math.random() * width;\n        this.y = Math.random() * height;\n        this.size = Math.random() * 1.5 + 0.5;\n        this.speedX = Math.random() * 0.15 - 0.075;\n        this.speedY = Math.random() * -0.3 - 0.05; // slowly drifting upwards\n        this.opacity = Math.random() * 0.5 + 0.1;\n        this.opacitySpeed = Math.random() * 0.005 + 0.002;\n      }\n\n      update() {\n        this.x += this.speedX;\n        this.y += this.speedY;\n        \n        // Loop particles when they drift out\n        if (this.y < 0) {\n          this.y = height;\n          this.x = Math.random() * width;\n        }\n        if (this.x < 0 || this.x > width) {\n          this.x = Math.random() * width;\n        }\n\n        // Pulse opacity\n        this.opacity += this.opacitySpeed;\n        if (this.opacity > 0.75 || this.opacity < 0.1) {\n          this.opacitySpeed = -this.opacitySpeed;\n        }\n      }\n\n      draw(context: CanvasRenderingContext2D) {\n        context.fillStyle = `rgba(251, 191, 36, ${this.opacity})`; // Golden color hex FBBF24\n        context.shadowColor = \'rgba(251, 191, 36, 0.4)\';\n        context.shadowBlur = 4;\n        context.beginPath();\n        context.arc(this.x, this.y, this.size, 0, Math.PI * 2);\n        context.fill();\n        context.shadowBlur = 0; // reset\n      }\n    }\n\n    const particles: Particle[] = Array.from({ length: 65 }, () => new Particle());\n\n    const animate = () => {\n      ctx.clearRect(0, 0, width, height);\n      particles.forEach(p => {\n        p.update();\n        p.draw(ctx);\n      });\n      animationFrameId = requestAnimationFrame(animate);\n    };\n\n    animate();\n\n    return () => {\n      cancelAnimationFrame(animationFrameId);\n      resizeObserver.disconnect();\n    };\n  }, []);\n\n  // Set design active and trigger AI stylist chat drawer\n  const handleAskStylist = (design: CustomJewelryDesign) => {\n    setActiveDesign(design);\n    setIsStylistOpen(true);\n  };\n\n  const handleAskStylistAboutItem = (item: CollectionItem) => {\n    // Map collection item to custom design format for conversational context\n    const design: CustomJewelryDesign = {\n      type: item.type,\n      metal: item.metal,\n      gemstone: item.gemstone,\n      cut: item.cut || \'Brillante\',\n      carats: parseFloat(item.specs.weight.split(\' \')[0]) || 2.5,\n      engraving: \'\',\n    };\n    setActiveDesign(design);\n    setIsStylistOpen(true);\n  };\n\n  const handleLoadIntoCustomizer = (design: CustomJewelryDesign) => {\n    // This state can be loaded inside the customizer using a prop callback\n    // For seamless UX, the Customizer triggers its update\n    setActiveDesign(design);\n  };\n\n  // Scroll to section helper\n  const scrollTo = (id: string) => {\n    const el = document.getElementById(id);\n    if (el) {\n      el.scrollIntoView({ behavior: \'smooth\', block: \'start\' });\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#050505] text-white font-sans relative overflow-x-hidden selection:bg-amber-500 selection:text-black\">\n      \n      {/* Background Static Shader / Stars layer */}\n      <div className=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(28,25,23,0.15)_0%,transparent_100%)] pointer-events-none z-0\" />\n      \n      {/* Dynamic Floating Golden Dust Canvas */}\n      <canvas ref={canvasRef} className=\"fixed inset-0 w-full h-full pointer-events-none z-10 opacity-70\" />\n\n      {/* LUXURY FLOATING HEADER */}\n      <header \n        className={`fixed top-0 left-0 right-0 z-40 transition-all duration-500 border-b ${\n          scrolled \n            ? \'bg-black/80 backdrop-blur-md border-amber-500/10 py-3 shadow-[0_10px_30px_rgba(0,0,0,0.8)]\' \n            : \'bg-transparent border-transparent py-6\'\n        }`}\n      >\n        <div className=\"max-w-7xl mx-auto px-6 sm:px-8 flex justify-between items-center\">\n          {/* Coordinates Clock Block */}\n          <div className=\"hidden lg:flex items-center gap-3 text-[11px] tracking-widest font-mono text-gray-400\">\n            <Clock className=\"w-3.5 h-3.5 text-amber-500/70\" />\n            <div className=\"flex gap-2.5\">\n              {([\'Par\303\255s\', \'Ginebra\', \'Tokio\'] as const).map(city => (\n                <button\n                  key={city}\n                  onClick={() => setActiveCity(city)}\n                  className={`transition-colors duration-200 cursor-pointer hover:text-amber-400 ${\n                    activeCity === city ? \'text-amber-400 font-bold\' : \'text-gray-500\'\n                  }`}\n                >\n                  {city.toUpperCase()}\n                </button>\n              ))}\n            </div>\n            <span className=\"text-amber-500 font-medium font-mono min-w-[70px]\">{time}</span>\n          </div>\n\n          {/* Logo Brand Brand Mark */}\n          <div className=\"flex flex-col items-center cursor-pointer select-none\" onClick={() => window.scrollTo({ top: 0, behavior: \'smooth\' })}>\n            <span className=\"text-3xl font-light tracking-[0.25em] text-white font-serif uppercase\">\n              AURA\n            </span>\n            <span className=\"text-[9px] tracking-[0.4em] text-amber-500 uppercase font-mono mt-0.5\">\n              HAUTE JOAILLERIE\n            </span>\n          </div>\n\n          {/* Luxury Navigation Panel */}\n          <div className=\"flex items-center gap-4 sm:gap-6\">\n            <nav className=\"hidden md:flex items-center gap-8 text-xs uppercase tracking-widest font-mono text-gray-400\">\n              <button onClick={() => scrollTo(\'atelier-section\')} className=\"hover:text-amber-400 transition-colors duration-200 cursor-pointer\">\n                El Atelier\n              </button>\n              <button onClick={() => scrollTo(\'coleccion-section\')} className=\"hover:text-amber-400 transition-colors duration-200 cursor-pointer\">\n                Colecci\303\263n Imperial\n              </button>\n              <button onClick={() => scrollTo(\'valores-section\')} className=\"hover:text-amber-400 transition-colors duration-200 cursor-pointer\">\n                Nuestra Filosof\303\255a\n              </button>\n            </nav>\n\n            <button\n              onClick={() => setIsStylistOpen(true)}\n              className=\"relative px-4 py-2 sm:px-5 sm:py-2.5 rounded-full bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 hover:text-amber-300 border border-amber-500/30 hover:border-amber-500/60 text-[11px] uppercase tracking-wider font-mono transition-all duration-300 flex items-center gap-2 cursor-pointer shadow-[0_0_15px_rgba(251,191,36,0.05)] hover:shadow-[0_0_20px_rgba(251,191,36,0.15)] active:scale-95\"\n            >\n              <Sparkles className=\"w-3.5 h-3.5 animate-pulse\" />\n              <span>Consultar IA</span>\n              {activeDesign && (\n                <span className=\"absolute -top-1 -right-1 w-2.5 h-2.5 bg-emerald-500 rounded-full border border-black animate-bounce\" />\n              )}\n            </button>\n          </div>\n        </div>\n      </header>\n\n      {/* HERO SECTION - CINEMATIC ENTRY */}\n      <section className=\"relative min-h-screen flex flex-col justify-center items-center px-6 text-center overflow-hidden bg-black pt-20\">\n        {/* Background Ambient Glowing Elements */}\n        <div className=\"absolute top-[40%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-5xl aspect-square bg-[radial-gradient(circle_at_center,rgba(146,110,38,0.12)_0%,transparent_60%)] pointer-events-none\" />\n\n        <div className=\"z-10 max-w-4xl space-y-6\">\n          <motion.div\n            initial={{ opacity: 0, y: -20 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 0.8, delay: 0.2 }}\n            className=\"flex items-center justify-center gap-2.5 text-xs tracking-[0.5em] font-mono text-amber-400 uppercase\"\n          >\n            <Sparkles className=\"w-4 h-4 text-amber-400 animate-spin-slow\" />\n            <span>Atelier de Piezas Singulares</span>\n            <Sparkles className=\"w-4 h-4 text-amber-400 animate-spin-slow\" />\n          </motion.div>\n\n          <motion.h1\n            initial={{ opacity: 0, scale: 0.96 }}\n            animate={{ opacity: 1, scale: 1 }}\n            transition={{ duration: 1.2, delay: 0.4, ease: [0.16, 1, 0.3, 1] }}\n            className=\"text-4xl sm:text-6xl md:text-7xl lg:text-8xl font-light tracking-wide text-white leading-tight font-serif\"\n          >\n            El Fulgor Eterno <br />\n            <span className=\"italic font-serif bg-gradient-to-r from-amber-200 via-yellow-400 to-amber-100 bg-clip-text text-transparent\">\n              de su Leyenda\n            </span>\n          </motion.h1>\n\n          <motion.p\n            initial={{ opacity: 0, y: 20 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 1, delay: 0.6 }}\n            className=\"text-sm sm:text-base md:text-lg text-gray-400 font-light max-w-2xl mx-auto leading-relaxed tracking-wide font-sans\"\n          >\n            Esculpimos sue\303\261os en metales nobles y constelaciones de gemas certificadas. \n            Experimente la simetr\303\255a absoluta de la alta costura orfebre y dialogue con nuestra maestra de estilo.\n          </motion.p>\n\n          <motion.div\n            initial={{ opacity: 0, y: 25 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 0.8, delay: 0.8 }}\n            className=\"pt-6 flex flex-col sm:flex-row gap-4 justify-center items-center\"\n          >\n            <button\n              onClick={() => scrollTo(\'atelier-section\')}\n              className=\"w-full sm:w-auto bg-gradient-to-r from-amber-500 via-yellow-600 to-amber-700 hover:from-amber-400 hover:to-amber-500 text-black px-8 py-3.5 rounded-xl font-medium tracking-widest text-xs uppercase shadow-lg shadow-yellow-500/10 transition-all cursor-pointer\"\n            >\n              Forjar Mi Dise\303\261o\n            </button>\n            <button\n              onClick={() => scrollTo(\'coleccion-section\')}\n              className=\"w-full sm:w-auto bg-white/5 hover:bg-white/10 border border-white/10 hover:border-amber-500/30 text-white px-8 py-3.5 rounded-xl font-medium tracking-widest text-xs uppercase transition-all cursor-pointer\"\n            >\n              Ver Tesoro Imperial\n            </button>\n          </motion.div>\n        </div>\n\n        {/* Scroll prompt */}\n        <div className=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 cursor-pointer z-20 text-gray-500 hover:text-amber-400 transition-colors duration-300\" onClick={() => scrollTo(\'atelier-section\')}>\n          <span className=\"text-[10px] tracking-[0.3em] uppercase font-mono font-light\">Descubrir</span>\n          <ChevronDown className=\"w-4 h-4 animate-bounce text-amber-500\" />\n        </div>\n      </section>\n\n      {/* SECTION 1: INTERACTIVE SIMULATION ATELIER */}\n      <section id=\"atelier-section\" className=\"py-24 sm:py-32 px-6 sm:px-8 max-w-7xl mx-auto border-t border-white/5 relative z-20 bg-black/30 rounded-t-3xl shadow-[0_-20px_40px_rgba(0,0,0,0.9)]\">\n        <div className=\"space-y-4 text-center max-w-3xl mx-auto mb-16\">\n          <span className=\"text-xs uppercase tracking-[0.4em] font-mono text-amber-500 block\">Atelier Virtual de Alta Costura</span>\n          <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white font-serif\">Simular Su Pr\303\263xima Reliquia</h2>\n          <div className=\"w-12 h-[1px] bg-amber-500 mx-auto mt-4\" />\n          <p className=\"text-sm text-gray-400 font-light leading-relaxed max-w-xl mx-auto\">\n            Moldee su visi\303\263n combinando el metal con gemas imperiales. La maestra de dise\303\261o Aurelia analizar\303\241 en tiempo real su simetr\303\255a est\303\251tica.\n          </p>\n        </div>\n\n        {/* Customized element block */}\n        <AtelierCustomizer onAskStylist={handleAskStylist} />\n      </section>\n\n      {/* SECTION 2: IMPERIAL SHOWCASE COLLECTION */}\n      <section id=\"coleccion-section\" className=\"py-24 sm:py-32 px-6 sm:px-8 max-w-7xl mx-auto border-t border-white/5 relative z-20\">\n        <div className=\"space-y-4 text-center max-w-3xl mx-auto mb-16\">\n          <span className=\"text-xs uppercase tracking-[0.4em] font-mono text-amber-500 block\">Curadur\303\255a Exclusiva de Temporada</span>\n          <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white font-serif\">La Colecci\303\263n Imperial</h2>\n          <div className=\"w-12 h-[1px] bg-amber-500 mx-auto mt-4\" />\n          <p className=\"text-sm text-gray-400 font-light leading-relaxed max-w-xl mx-auto\">\n            Explore nuestras obras maestras atemporales, forjadas por orfebres de \303\251lite bajo las fases de los solsticios m\303\241s radiantes.\n          </p>\n        </div>\n\n        <CollectionGrid \n          onLoadIntoCustomizer={handleLoadIntoCustomizer} \n          onAskStylistAboutItem={handleAskStylistAboutItem} \n        />\n      </section>\n\n      {/* SECTION 3: REFINED CORE VALUES / ETHICS */}\n      <section id=\"valores-section\" className=\"py-24 sm:py-32 px-6 sm:px-8 max-w-7xl mx-auto border-t border-white/5 relative z-20\">\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          <div className=\"lg:col-span-5 space-y-6\">\n            <span className=\"text-xs uppercase tracking-[0.3em] font-mono text-amber-500 block\">Compromiso \303\211tico e Imperecedero</span>\n            <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white leading-tight font-serif\">El Respeto Absoluto al Origen</h2>\n            <div className=\"w-12 h-[1px] bg-amber-500\" />\n            <p className=\"text-sm text-gray-300 font-light leading-relaxed\">\n              En AURA Haute Joaillerie, creemos que la belleza de una gema no radica \303\272nicamente en su refracci\303\263n de luz, sino en la pureza de su trayecto hasta sus manos. \n              Garantizamos diamantes libres de conflictos y oro recolectado bajo protocolos de sustentabilidad total.\n            </p>\n            <div className=\"space-y-3 pt-4\">\n              <div className=\"flex items-start gap-3\">\n                <div className=\"w-6 h-6 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 mt-0.5\">\n                  <ShieldCheck className=\"w-3.5 h-3.5 text-amber-400\" />\n                </div>\n                <div>\n                  <span className=\"text-xs font-semibold text-white block\">Certificaci\303\263n del Kimberley Process</span>\n                  <span className=\"text-[11px] text-gray-400\">Cada diamante se rastrea desde la mina oficial respetando los derechos de las comunidades locales.</span>\n                </div>\n              </div>\n              <div className=\"flex items-start gap-3\">\n                <div className=\"w-6 h-6 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 mt-0.5\">\n                  <Award className=\"w-3.5 h-3.5 text-amber-400\" />\n                </div>\n                <div>\n                  <span className=\"text-xs font-semibold text-white block\">Metales Fairmined Garantizados</span>\n                  <span className=\"text-[11px] text-gray-400\">Soportamos directamente la miner\303\255a artesanal \303\251tica y responsable libre de agentes mercuriales nocivos.</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-7 grid grid-cols-2 gap-4\">\n            <div className=\"space-y-4\">\n              <div className=\"rounded-2xl overflow-hidden aspect-[4/5] bg-zinc-950 border border-white/5 relative group\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?auto=format&fit=crop&q=80&w=800\" \n                  alt=\"Crafting diamond\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\"\n                />\n                <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" />\n                <span className=\"absolute bottom-4 left-4 text-xs font-mono text-amber-400 uppercase tracking-widest\">Orfebrer\303\255a Cincelada</span>\n              </div>\n              <div className=\"rounded-2xl bg-gradient-to-br from-amber-500/10 to-transparent border border-amber-500/10 p-6 space-y-2\">\n                <h4 className=\"text-lg font-serif font-light text-amber-400\">100+ Horas</h4>\n                <p className=\"text-xs text-gray-400 leading-relaxed\">De dedicaci\303\263n manual absoluta invertida por pieza por orfebres con maestr\303\255a heredada.</p>\n              </div>\n            </div>\n            \n            <div className=\"space-y-4 pt-8\">\n              <div className=\"rounded-2xl bg-zinc-900/40 border border-white/5 p-6 space-y-2\">\n                <h4 className=\"text-lg font-serif font-light text-amber-400\">GIA Superior</h4>\n                <p className=\"text-xs text-gray-400 leading-relaxed\">Evaluaci\303\263n rigurosa bajo el laboratorio gemol\303\263gico m\303\241s estricto del globo terrestre.</p>\n              </div>\n              <div className=\"rounded-2xl overflow-hidden aspect-[4/5] bg-zinc-950 border border-white/5 relative group\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1617038260897-41a1f14a8ca0?auto=format&fit=crop&q=80&w=800\" \n                  alt=\"Finished masterpiece\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\"\n                />\n                <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" />\n                <span className=\"absolute bottom-4 left-4 text-xs font-mono text-amber-400 uppercase tracking-widest\">Reliquias Imperiales</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* LUXURY EMBELLISHED FOOTER */}\n      <footer className=\"bg-black py-16 px-6 sm:px-8 border-t border-white/10 relative z-20 text-gray-400\">\n        <div className=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-8 items-start mb-12\">\n          {/* Logo brand info column */}\n          <div className=\"md:col-span-5 space-y-4 text-center md:text-left\">\n            <h3 className=\"text-2xl font-light tracking-widest text-white font-serif\">Maison AURA</h3>\n            <p className=\"text-xs text-gray-400 font-light leading-relaxed max-w-sm mx-auto md:mx-0\">\n              Inspirados en la geometr\303\255a celeste y la orfebrer\303\255a imperial de Par\303\255s, forjamos piezas singulares de belleza imperecedera.\n            </p>\n            <div className=\"pt-2 text-xs font-mono text-amber-500/70 tracking-widest\">\n              PAR\303\215S \342\200\242 GINEBRA \342\200\242 TOKIO\n            </div>\n          </div>\n\n          {/* Links column */}\n          <div className=\"md:col-span-3 space-y-2 text-center md:text-left\">\n            <h4 className=\"text-xs font-semibold tracking-wider text-white uppercase font-mono\">Navegaci\303\263n</h4>\n            <ul className=\"text-xs space-y-2 font-light\">\n              <li><button onClick={() => window.scrollTo({ top: 0, behavior: \'smooth\' })} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Volver al Firmamento</button></li>\n              <li><button onClick={() => scrollTo(\'atelier-section\')} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Atelier Simulador</button></li>\n              <li><button onClick={() => scrollTo(\'coleccion-section\')} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Cat\303\241logo Imperial</button></li>\n            </ul>\n          </div>\n\n          {/* Contact coordinates column */}\n          <div className=\"md:col-span-4 space-y-2 text-center md:text-left\">\n            <h4 className=\"text-xs font-semibold tracking-wider text-white uppercase font-mono\">Atenci\303\263n Exclusiva</h4>\n            <ul className=\"text-xs space-y-1.5 font-light\">\n              <li className=\"text-amber-500 font-medium\">salonal@aura-hautejoaillerie.com</li>\n              <li>Place Vend\303\264me 14, 75001 Par\303\255s, Francia</li>\n              <li className=\"text-[10px] text-gray-500 pt-1 font-mono\">Horario del Taller: Lunes a S\303\241bado de 10:00 a 19:00 (CET)</li>\n            </ul>\n          </div>\n        </div>\n\n        {/* Bottom copyright declaration */}\n        <div className=\"max-w-7xl mx-auto pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center text-[11px] text-gray-600 gap-4\">\n          <p>\302\251 {new Date().getFullYear()} AURA Joyer\303\255a. Todos los derechos reservados. Miembro del Sindicato de Alta Orfebrer\303\255a.</p>\n          <div className=\"flex gap-4 font-mono uppercase tracking-wider text-[10px]\">\n            <span className=\"hover:text-gray-400 transition-colors cursor-pointer\">Seguridad GIA</span>\n            <span>\342\200\242</span>\n            <span className=\"hover:text-gray-400 transition-colors cursor-pointer\">Sello de Sustentabilidad</span>\n          </div>\n        </div>\n      </footer>\n\n      {/* FLOATING CHAT DRAWER PANEL */}\n      <AIStylist\n        currentDesign={activeDesign}\n        onClearDesign={() => setActiveDesign(null)}\n        isOpen={isStylistOpen}\n        onClose={() => setIsStylistOpen(false)}\n      />\n\n    </div>\n  );\n}\n"
    }
    diff {
      end_line: 8
      unified_diff {
        lines {
          text: "/**"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: " * @license"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
