    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { CollectionItem } from \'./types\';\n\nexport const EXQUISITE_COLLECTION: CollectionItem[] = [\n  {\n    id: \'coll-1\',\n    name: \'Miami King Cuban Link\',\n    type: \'Cadena\',\n    description: \'La legendaria cadena Miami Cuban Link de 15 mm en Oro de 14K, densamente engastada a mano con Moissanita VVS brillante.\',\n    price: \'\342\202\2546,800\',\n    image: \'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Amarillo 14K\',\n    gemstone: \'Moissanita VVS\',\n    cut: \'Micro-Pave\',\n    story: \'S\303\255mbolo indiscutible de estatus y cultura streetwear. Cada eslab\303\263n se funde con precisi\303\263n geom\303\251trica perfecta y se reviste con una constelaci\303\263n de gemas que reflejan el destello de los flashes en los escenarios internacionales.\',\n    specs: {\n      weight: \'32.5 Quilates total\',\n      clarity: \'VVS1 Color D (Passed Tester)\',\n      origin: \'Atelier AYA GOLDEN, Mil\303\241n\'\n    }\n  },\n  {\n    id: \'coll-2\',\n    name: \'Faraoh\\\'s Destiny Pendant\',\n    type: \'Colgante\',\n    description: \'Imponente colgante del Fara\303\263n en Oro de 14K, engastado con una corona de Moissanita y ojos de Esmeralda Imperial.\',\n    price: \'\342\202\2544,200\',\n    image: \'https://images.unsplash.com/photo-1605100804763-247f67b3557e?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Amarillo 14K\',\n    gemstone: \'Esmeralda Imperial\',\n    cut: \'Solitario\',\n    story: \'Inspirado en la opulencia divina del antiguo Egipto y fusionado con la est\303\251tica urbana contempor\303\241nea. El rostro del Fara\303\263n est\303\241 tallado tridimensionalmente en oro macizo, custodiado por gemas de refracci\303\263n verde y diamantes pav\303\251.\',\n    specs: {\n      weight: \'12.4 Quilates total\',\n      clarity: \'VVS2 Flawless Cut\',\n      origin: \'Dise\303\261o Limitado de la Maison\'\n    }\n  },\n  {\n    id: \'coll-3\',\n    name: \'Imperial VVS Tennis Drip\',\n    type: \'Brazalete\',\n    description: \'Brazalete Tennis cl\303\241sico de 5 mm en Oro Blanco de 14K, engastado con Moissanita VVS en garras de corte sim\303\251trico.\',\n    price: \'\342\202\2542,950\',\n    image: \'https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Blanco 14K\',\n    gemstone: \'Moissanita VVS\',\n    cut: \'Prong Set\',\n    story: \'La fluidez hecha hielo. Dise\303\261ado para deslizarse c\303\263modamente sobre la mu\303\261eca, el set Tennis se ha convertido en el cl\303\241sico definitivo del hip-hop premium, brindando un brillo ininterrumpido bajo cualquier condici\303\263n de luz.\',\n    specs: {\n      weight: \'18.2 Quilates total\',\n      clarity: \'VVS1 Ideal Cut\',\n      origin: \'Laboratorios de Alta Precisi\303\263n\'\n    }\n  },\n  {\n    id: \'coll-4\',\n    name: \'Vampire Fangz Grillz Set\',\n    type: \'Grillz\',\n    description: \'Set de Grillz premium para caninos en Oro Blanco de 14K y Plata .925, cubierto enteramente con Moissanita y Rub\303\255 Lab-Grown.\',\n    price: \'\342\202\2545,400\',\n    image: \'https://images.unsplash.com/photo-1617038260897-41a1f14a8ca0?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Blanco 14K\',\n    gemstone: \'Rub\303\255 Lab-Grown\',\n    cut: \'Baguette Cut\',\n    story: \'Una obra orfebre de ajuste dental perfecto hecha a la medida. Forjada para quienes desaf\303\255an los l\303\255mites est\303\251ticos, combinando colmillos helados con baguettes rojas de rub\303\255es sint\303\251ticos de m\303\241xima pureza.\',\n    specs: {\n      weight: \'8.5 Quilates de piedras\',\n      clarity: \'Perfect Dental Grade .925\',\n      origin: \'Atelier Bucal de Lujo, Tokio\'\n    }\n  },\n  {\n    id: \'coll-5\',\n    name: \'Royal Midnight Band\',\n    type: \'Anillo\',\n    description: \'Anillo de sello pavonado en plata pesada con un pav\303\251 continuo de Diamante Negro de destello misterioso y elegante.\',\n    price: \'\342\202\2541,850\',\n    image: \'https://images.unsplash.com/photo-1602751584552-8ba73aad10e1?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Plata de Ley .925\',\n    gemstone: \'Diamante Negro\',\n    cut: \'Micro-Pave\',\n    story: \'Para los soberanos de la noche. La refracci\303\263n oscura de los diamantes negros tallados a mano contrasta con el brillo cepillado de la plata de ley pulida, ofreciendo un aire sofisticado y rebelde a la vez.\',\n    specs: {\n      weight: \'6.4 Quilates\',\n      clarity: \'Excellent Black Polish\',\n      origin: \'Forjas de AYA GOLDEN\'\n    }\n  }\n];\n"
    }
