    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\nimport { CustomJewelryDesign, JewelryType, MetalType, GemstoneType, GemstoneCut } from \'../types\';\nimport { Sparkles, Hammer, MessageSquare, ShieldAlert, Award, Sliders } from \'lucide-react\';\nimport { motion } from \'motion/react\';\n\ninterface AtelierCustomizerProps {\n  onAskStylist: (design: CustomJewelryDesign) => void;\n}\n\nconst JEWELRY_TYPES: { value: JewelryType; label: string; icon: string }[] = [\n  { value: \'Anillo\', label: \'Anillo de Compromiso\', icon: \'\360\237\222\215\' },\n  { value: \'Collar\', label: \'Collar de Gala\', icon: \'\360\237\223\277\' },\n  { value: \'Pendientes\', label: \'Pendientes Imperiales\', icon: \'\342\234\250\' },\n  { value: \'Brazalete\', label: \'Brazalete Eterno\', icon: \'\360\237\222\253\' },\n];\n\nconst METALS: { value: MetalType; label: string; bgClass: string; textClass: string; colorHex: string; glowHex: string }[] = [\n  { value: \'Oro Amarillo 18K\', label: \'Oro Amarillo 18K\', bgClass: \'bg-amber-100 border-amber-400\', textClass: \'text-amber-300\', colorHex: \'#FBBF24\', glowHex: \'rgba(251, 191, 36, 0.4)\' },\n  { value: \'Oro Rosa 18K\', label: \'Oro Rosa 18K\', bgClass: \'bg-rose-100 border-rose-300\', textClass: \'text-rose-300\', colorHex: \'#FCA5A5\', glowHex: \'rgba(252, 165, 165, 0.4)\' },\n  { value: \'Oro Blanco 18K\', label: \'Oro Blanco 18K\', bgClass: \'bg-slate-100 border-slate-300\', textClass: \'text-slate-300\', colorHex: \'#E2E8F0\', glowHex: \'rgba(226, 232, 240, 0.4)\' },\n  { value: \'Platino\', label: \'Platino Puro 950\', bgClass: \'bg-zinc-200 border-zinc-400\', textClass: \'text-zinc-300\', colorHex: \'#D1D5DB\', glowHex: \'rgba(209, 213, 219, 0.3)\' },\n];\n\nconst GEMSTONES: { value: GemstoneType; label: string; colorHex: string; glowHex: string; bgClass: string; energy: string }[] = [\n  { value: \'Diamante\', label: \'Diamante Imperial\', colorHex: \'#E0F2FE\', glowHex: \'rgba(224, 242, 254, 0.7)\', bgClass: \'bg-sky-50 border-sky-200 text-sky-800\', energy: \'Pureza & Eternidad\' },\n  { value: \'Esmeralda\', label: \'Esmeralda Colombiana\', colorHex: \'#10B981\', glowHex: \'rgba(16, 185, 129, 0.7)\', bgClass: \'bg-emerald-50 border-emerald-200 text-emerald-800\', energy: \'Prosperidad & Renacimiento\' },\n  { value: \'Zafiro\', label: \'Zafiro de Ceyl\303\241n\', colorHex: \'#1D4ED8\', glowHex: \'rgba(29, 78, 216, 0.7)\', bgClass: \'bg-blue-50 border-blue-200 text-blue-800\', energy: \'Sabidur\303\255a & Verdad\' },\n  { value: \'Rub\303\255\', label: \'Rub\303\255 Sangre de Pich\303\263n\', colorHex: \'#EF4444\', glowHex: \'rgba(239, 68, 68, 0.7)\', bgClass: \'bg-red-50 border-red-200 text-red-800\', energy: \'Pasi\303\263n & Coraje\' },\n  { value: \'Amatista\', label: \'Amatista M\303\255stica\', colorHex: \'#8B5CF6\', glowHex: \'rgba(139, 92, 246, 0.7)\', bgClass: \'bg-purple-50 border-purple-200 text-purple-800\', energy: \'Calma & Espiritualidad\' },\n  { value: \'Ninguna\', label: \'Sin Gema (Solo Metal)\', colorHex: \'transparent\', glowHex: \'transparent\', bgClass: \'bg-gray-100 border-gray-200 text-gray-500\', energy: \'Elegancia Minimalista\' },\n];\n\nconst CUTS: { value: GemstoneCut; label: string; description: string }[] = [\n  { value: \'Brillante\', label: \'Brillante (Round)\', description: \'M\303\241ximo destello y refracci\303\263n\' },\n  { value: \'Princesa\', label: \'Princesa (Square)\', description: \'Geometr\303\255a moderna y audaz\' },\n  { value: \'Esmeralda\', label: \'Esmeralda (Step-cut)\', description: \'Claridad e ilusi\303\263n de espejos\' },\n  { value: \'Pera\', label: \'Talla Pera (Teardrop)\', description: \'Silueta fluida y de alta costura\' },\n  { value: \'Coj\303\255n\', label: \'Talla Coj\303\255n (Cushion)\', description: \'Lados curvos con romance vintage\' },\n];\n\nexport default function AtelierCustomizer({ onAskStylist }: AtelierCustomizerProps) {\n  const [design, setDesign] = useState<CustomJewelryDesign>({\n    type: \'Anillo\',\n    metal: \'Oro Amarillo 18K\',\n    gemstone: \'Esmeralda\',\n    cut: \'Esmeralda\',\n    carats: 2.0,\n    engraving: \'\',\n  });\n\n  const activeMetal = METALS.find(m => m.value === design.metal) || METALS[0];\n  const activeGem = GEMSTONES.find(g => g.value === design.gemstone) || GEMSTONES[0];\n\n  const handleTypeChange = (type: JewelryType) => {\n    setDesign(prev => ({ ...prev, type }));\n  };\n\n  const handleMetalChange = (metal: MetalType) => {\n    setDesign(prev => ({ ...prev, metal }));\n  };\n\n  const handleGemstoneChange = (gemstone: GemstoneType) => {\n    setDesign(prev => ({ \n      ...prev, \n      gemstone,\n      // If none selected, don\'t worry about cut\n    }));\n  };\n\n  const handleCutChange = (cut: GemstoneCut) => {\n    setDesign(prev => ({ ...prev, cut }));\n  };\n\n  const handleCaratChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    setDesign(prev => ({ ...prev, carats: parseFloat(e.target.value) }));\n  };\n\n  const handleEngravingChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const text = e.target.value.slice(0, 24); // Limit engraving to 24 characters\n    setDesign(prev => ({ ...prev, engraving: text }));\n  };\n\n  // Base dimensions based on Carats for SVG\n  const gemSizeFactor = Math.min(Math.max(design.carats * 12, 10), 55);\n\n  return (\n    <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 text-white max-w-6xl mx-auto items-stretch\" id=\"atelier-customizer\">\n      {/* LEFT: Live Interactive Preview */}\n      <div className=\"lg:col-span-5 flex flex-col justify-between bg-black/60 backdrop-blur-md rounded-2xl p-6 border border-yellow-500/20 relative overflow-hidden\">\n        {/* Decorative Golden Corner Glows */}\n        <div className=\"absolute top-0 left-0 w-32 h-32 bg-amber-500/10 rounded-full filter blur-2xl pointer-events-none\" />\n        <div className=\"absolute bottom-0 right-0 w-32 h-32 bg-amber-500/10 rounded-full filter blur-2xl pointer-events-none\" />\n\n        <div className=\"flex justify-between items-center z-10\">\n          <div className=\"flex items-center gap-2\">\n            <Hammer className=\"w-4 h-4 text-amber-400\" />\n            <span className=\"text-xs uppercase tracking-widest font-mono text-amber-400\">Atelier de Simulaci\303\263n</span>\n          </div>\n          <span className=\"text-[10px] font-mono text-gray-400 uppercase tracking-wider bg-white/5 px-2 py-1 rounded-md\">\n            950/1000 Oro-Plat\n          </span>\n        </div>\n\n        {/* Central SVG Render Engine */}\n        <div className=\"my-8 flex justify-center items-center h-64 relative z-10\">\n          {/* Glowing background ring behind gem */}\n          {design.gemstone !== \'Ninguna\' && (\n            <motion.div\n              animate={{\n                scale: [1, 1.1, 1],\n                opacity: [0.3, 0.5, 0.3],\n              }}\n              transition={{\n                duration: 4,\n                repeat: Infinity,\n                ease: \"easeInOut\",\n              }}\n              style={{\n                background: `radial-gradient(circle, ${activeGem.glowHex} 0%, transparent 70%)`,\n                width: `${gemSizeFactor * 3}px`,\n                height: `${gemSizeFactor * 3}px`,\n              }}\n              className=\"absolute rounded-full pointer-events-none\"\n            />\n          )}\n\n          <svg width=\"240\" height=\"240\" viewBox=\"0 0 200 200\" className=\"drop-shadow-[0_10px_30px_rgba(0,0,0,0.8)]\">\n            <defs>\n              <radialGradient id=\"metalGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n                <stop offset=\"0%\" stopColor=\"#FFFFFF\" />\n                <stop offset=\"50%\" stopColor={activeMetal.colorHex} />\n                <stop offset=\"100%\" stopColor=\"#1C1917\" />\n              </radialGradient>\n              \n              <linearGradient id=\"metalLine\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n                <stop offset=\"0%\" stopColor={activeMetal.colorHex} stopOpacity=\"0.8\" />\n                <stop offset=\"50%\" stopColor=\"#FFFFFF\" stopOpacity=\"0.9\" />\n                <stop offset=\"100%\" stopColor={activeMetal.colorHex} stopOpacity=\"0.8\" />\n              </linearGradient>\n\n              <radialGradient id=\"gemGrad\" cx=\"35%\" cy=\"35%\" r=\"65%\">\n                <stop offset=\"0%\" stopColor=\"#FFFFFF\" stopOpacity=\"0.9\" />\n                <stop offset=\"30%\" stopColor={activeGem.colorHex} stopOpacity=\"0.9\" />\n                <stop offset=\"100%\" stopColor=\"#040204\" stopOpacity=\"0.95\" />\n              </radialGradient>\n            </defs>\n\n            {/* DRAW JEWELRY BASE METAL */}\n            {design.type === \'Anillo\' && (\n              <g id=\"ring-base\">\n                {/* Main ring shank */}\n                <circle cx=\"100\" cy=\"115\" r=\"55\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"12\" />\n                <circle cx=\"100\" cy=\"115\" r=\"55\" fill=\"none\" stroke=\"#000\" strokeWidth=\"1\" strokeOpacity=\"0.3\" />\n                {/* Crown shoulders setting the gem */}\n                <path d=\"M78 68 C80 50, 90 48, 100 48 C110 48, 120 50, 122 68\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"10\" />\n                <path d=\"M88 56 L100 45 L112 56\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"5\" />\n              </g>\n            )}\n\n            {design.type === \'Collar\' && (\n              <g id=\"necklace-base\">\n                {/* Elegant Hanging Chain */}\n                <path d=\"M40 30 C 50 110, 150 110, 160 30\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"4\" strokeDasharray=\"3,3\" />\n                <path d=\"M60 30 C 70 120, 130 120, 140 30\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"2\" />\n                {/* Central luxurious loop holding pendant */}\n                <circle cx=\"100\" cy=\"98\" r=\"14\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"6\" />\n                <path d=\"M100 108 L100 120\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"8\" />\n              </g>\n            )}\n\n            {design.type === \'Pendientes\' && (\n              <g id=\"earrings-base\">\n                {/* Earring 1 hook and chain */}\n                <path d=\"M60 40 C 60 50, 50 70, 60 85\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"5\" />\n                <circle cx=\"60\" cy=\"85\" r=\"8\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"4\" />\n                <line x1=\"60\" y1=\"91\" x2=\"60\" y2=\"105\" stroke=\"url(#metalLine)\" strokeWidth=\"5\" />\n\n                {/* Earring 2 hook and chain */}\n                <path d=\"M140 40 C 140 50, 130 70, 140 85\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"5\" />\n                <circle cx=\"140\" cy=\"85\" r=\"8\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"4\" />\n                <line x1=\"140\" y1=\"91\" x2=\"140\" y2=\"105\" stroke=\"url(#metalLine)\" strokeWidth=\"5\" />\n              </g>\n            )}\n\n            {design.type === \'Brazalete\' && (\n              <g id=\"bracelet-base\">\n                {/* Luxury Open Cuff Cuff */}\n                <path d=\"M35 110 C 35 150, 165 150, 165 110\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"18\" strokeLinecap=\"round\" />\n                {/* Intricate detailed internal filigree lines */}\n                <path d=\"M45 118 C 45 142, 155 142, 155 118\" fill=\"none\" stroke=\"#111\" strokeWidth=\"2\" />\n                <path d=\"M35 110 C 35 150, 165 150, 165 110\" fill=\"none\" stroke=\"#FFF\" strokeWidth=\"1\" strokeDasharray=\"5,10\" strokeOpacity=\"0.5\" />\n                {/* Center plate setting */}\n                <rect x=\"80\" y=\"112\" width=\"40\" height=\"20\" rx=\"4\" fill=\"url(#metalLine)\" stroke={activeMetal.colorHex} strokeWidth=\"2\" />\n              </g>\n            )}\n\n            {/* DRAW THE GEMSTONE IN ITS RESOLVED POSITION */}\n            {design.gemstone !== \'Ninguna\' && (\n              <g id=\"gemstone-rendered\">\n                {/* Dynamically position based on type */}\n                {design.type === \'Anillo\' && (\n                  <g transform={`translate(100, 48)`}>\n                    {renderGemstoneShape(design.cut, gemSizeFactor, \'url(#gemGrad)\', activeGem.colorHex)}\n                  </g>\n                )}\n                {design.type === \'Collar\' && (\n                  <g transform={`translate(100, 126)`}>\n                    {renderGemstoneShape(design.cut, gemSizeFactor, \'url(#gemGrad)\', activeGem.colorHex)}\n                  </g>\n                )}\n                {design.type === \'Pendientes\' && (\n                  <>\n                    <g transform={`translate(60, 110)`}>\n                      {renderGemstoneShape(design.cut, gemSizeFactor * 0.75, \'url(#gemGrad)\', activeGem.colorHex)}\n                    </g>\n                    <g transform={`translate(140, 110)`}>\n                      {renderGemstoneShape(design.cut, gemSizeFactor * 0.75, \'url(#gemGrad)\', activeGem.colorHex)}\n                    </g>\n                  </>\n                )}\n                {design.type === \'Brazalete\' && (\n                  <g transform={`translate(100, 122)`}>\n                    {renderGemstoneShape(design.cut, gemSizeFactor, \'url(#gemGrad)\', activeGem.colorHex)}\n                  </g>\n                )}\n              </g>\n            )}\n\n            {/* ENGRAVING CAPTION */}\n            {design.engraving && (\n              <text\n                x=\"100\"\n                y=\"180\"\n                textAnchor=\"middle\"\n                fill=\"#FBBF24\"\n                fontSize=\"11\"\n                fontFamily=\"Cinzel, serif\"\n                fontStyle=\"italic\"\n                className=\"opacity-90 animate-pulse font-serif\"\n              >\n                &ldquo;{design.engraving}&rdquo;\n              </text>\n            )}\n          </svg>\n        </div>\n\n        {/* Info Card on Bottom of Preview */}\n        <div className=\"bg-white/5 border border-white/10 rounded-xl p-4 z-10 backdrop-blur-sm\">\n          <div className=\"flex justify-between items-start\">\n            <div>\n              <h4 className=\"text-sm font-semibold tracking-wide text-white font-sans\">{design.type} Especializado</h4>\n              <p className=\"text-xs text-gray-400 mt-0.5\">{design.metal} \342\200\242 {design.gemstone !== \'Ninguna\' ? `${design.gemstone} (${design.cut})` : \'Pureza de Metal\'}</p>\n            </div>\n            {design.gemstone !== \'Ninguna\' && (\n              <div className=\"text-right\">\n                <span className=\"text-xs px-2 py-0.5 bg-yellow-500/10 text-yellow-400 rounded-md border border-yellow-500/20 font-mono\">\n                  {design.carats.toFixed(1)} CT\n                </span>\n              </div>\n            )}\n          </div>\n          <div className=\"mt-3 pt-3 border-t border-white/5 flex items-center justify-between text-[11px]\">\n            <span className=\"text-gray-400\">Sinerg\303\255a de Alma:</span>\n            <span className=\"text-amber-400 font-medium tracking-wide flex items-center gap-1\">\n              <Sparkles className=\"w-3 h-3 text-amber-400\" />\n              {activeGem.energy}\n            </span>\n          </div>\n        </div>\n\n        <button\n          onClick={() => onAskStylist(design)}\n          className=\"mt-4 w-full bg-gradient-to-r from-amber-500 via-yellow-600 to-amber-700 hover:from-amber-400 hover:to-amber-600 text-black py-3 px-4 rounded-xl font-medium tracking-wide shadow-lg hover:shadow-yellow-500/20 transition-all duration-300 flex items-center justify-center gap-2 text-sm z-10 uppercase active:scale-[0.98]\"\n        >\n          <MessageSquare className=\"w-4 h-4 text-black fill-black\" />\n          <span>Preguntar a Maestra Aurelia (IA)</span>\n        </button>\n      </div>\n\n      {/* RIGHT: Detailed Configuration Controls */}\n      <div className=\"lg:col-span-7 flex flex-col justify-between bg-zinc-950/40 border border-white/10 rounded-2xl p-6 lg:p-8 backdrop-blur-md relative\">\n        <div className=\"space-y-6\">\n          <div className=\"flex items-center gap-2\">\n            <Sliders className=\"w-5 h-5 text-amber-500\" />\n            <h3 className=\"text-xl font-light tracking-wider text-amber-500 uppercase\">Personalizar Atributos</h3>\n          </div>\n\n          {/* 1. Jewelry Type */}\n          <div>\n            <label className=\"text-xs uppercase tracking-widest font-mono text-gray-400 block mb-3\">1. Tipo de Obra</label>\n            <div className=\"grid grid-cols-2 sm:grid-cols-4 gap-3\">\n              {JEWELRY_TYPES.map(jt => (\n                <button\n                  key={jt.value}\n                  onClick={() => handleTypeChange(jt.value)}\n                  className={`flex flex-col items-center justify-center p-3 rounded-xl border transition-all duration-300 ${\n                    design.type === jt.value\n                      ? \'border-amber-400 bg-amber-500/10 shadow-[0_0_12px_rgba(251,191,36,0.15)] text-white\'\n                      : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                  }`}\n                >\n                  <span className=\"text-2xl mb-1\">{jt.icon}</span>\n                  <span className=\"text-xs font-medium tracking-wide\">{jt.value}</span>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* 2. Metal selection */}\n          <div>\n            <label className=\"text-xs uppercase tracking-widest font-mono text-gray-400 block mb-3\">2. Metal Noble Base</label>\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n              {METALS.map(metal => (\n                <button\n                  key={metal.value}\n                  onClick={() => handleMetalChange(metal.value)}\n                  className={`flex items-center gap-3 p-3 rounded-xl border text-left transition-all duration-300 ${\n                    design.metal === metal.value\n                      ? \'border-amber-400 bg-amber-500/5 text-white\'\n                      : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                  }`}\n                >\n                  <span className={`w-5 h-5 rounded-full border ${metal.bgClass} flex-shrink-0`} />\n                  <div>\n                    <span className=\"text-xs font-semibold block\">{metal.label}</span>\n                    <span className=\"text-[10px] text-gray-400 uppercase tracking-wide font-mono\">Alta Orfebrer\303\255a</span>\n                  </div>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* 3. Gemstone selection */}\n          <div>\n            <label className=\"text-xs uppercase tracking-widest font-mono text-gray-400 block mb-3\">3. Gema Preciosa Central</label>\n            <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-2\">\n              {GEMSTONES.map(gem => (\n                <button\n                  key={gem.value}\n                  onClick={() => handleGemstoneChange(gem.value)}\n                  className={`p-2.5 rounded-xl border text-center transition-all duration-300 flex flex-col items-center ${\n                    design.gemstone === gem.value\n                      ? \'border-amber-400 bg-amber-500/10 text-white\'\n                      : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                  }`}\n                >\n                  {gem.value !== \'Ninguna\' ? (\n                    <span\n                      className=\"w-4 h-4 rounded-full mb-1 shadow-lg\"\n                      style={{\n                        backgroundColor: gem.colorHex,\n                        boxShadow: `0 0 10px ${gem.glowHex}`,\n                      }}\n                    />\n                  ) : (\n                    <span className=\"w-4 h-4 rounded-full bg-transparent border border-gray-600 mb-1\" />\n                  )}\n                  <span className=\"text-xs font-medium block leading-tight\">{gem.value}</span>\n                  <span className=\"text-[9px] text-gray-500 truncate max-w-full leading-none mt-0.5\">{gem.value === \'Ninguna\' ? \'Metal liso\' : gem.energy.split(\' \')[0]}</span>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* 4. Gemstone Cut (Conditionally visible) */}\n          {design.gemstone !== \'Ninguna\' && (\n            <div>\n              <label className=\"text-xs uppercase tracking-widest font-mono text-gray-400 block mb-3\">4. Talla y Facetado de Precisi\303\263n</label>\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-2\">\n                {CUTS.map(cut => (\n                  <button\n                    key={cut.value}\n                    onClick={() => handleCutChange(cut.value)}\n                    className={`p-2.5 rounded-xl border text-left transition-all duration-300 flex flex-col justify-between h-20 ${\n                      design.cut === cut.value\n                        ? \'border-amber-400 bg-amber-500/10 text-white\'\n                        : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                    }`}\n                  >\n                    <span className=\"text-xs font-bold\">{cut.label}</span>\n                    <span className=\"text-[9px] text-gray-400 leading-tight mt-1\">{cut.description}</span>\n                  </button>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* 5. Carats (Conditionally visible) */}\n          {design.gemstone !== \'Ninguna\' && (\n            <div>\n              <div className=\"flex justify-between items-center mb-2\">\n                <label className=\"text-xs uppercase tracking-widest font-mono text-gray-400\">5. Peso de la Gema (Quilates)</label>\n                <span className=\"text-xs font-mono text-amber-400 font-semibold bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20\">\n                  {design.carats.toFixed(2)} CT\n                </span>\n              </div>\n              <input\n                type=\"range\"\n                min=\"0.5\"\n                max=\"5.0\"\n                step=\"0.1\"\n                value={design.carats}\n                onChange={handleCaratChange}\n                className=\"w-full accent-amber-500 h-1 bg-white/10 rounded-lg cursor-pointer\"\n              />\n              <div className=\"flex justify-between text-[10px] text-gray-500 mt-1 font-mono\">\n                <span>0.5 CT (Discreto)</span>\n                <span>2.5 CT (Elegante)</span>\n                <span>5.0 CT (Majestuoso)</span>\n              </div>\n            </div>\n          )}\n\n          {/* 6. Engraving */}\n          <div>\n            <label className=\"text-xs uppercase tracking-widest font-mono text-gray-400 block mb-2\">\n              {design.gemstone !== \'Ninguna\' ? \'6. Inscripci\303\263n en el Oro / Platino\' : \'4. Inscripci\303\263n de Orfebrer\303\255a\'}\n            </label>\n            <input\n              type=\"text\"\n              value={design.engraving}\n              onChange={handleEngravingChange}\n              placeholder=\"Ej: S & A - Eterno Crep\303\272sculo\"\n              maxLength={24}\n              className=\"w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-400 focus:bg-white/10 transition-all duration-300\"\n            />\n            <p className=\"text-[10px] text-gray-500 mt-1 text-right\">M\303\241x 24 letras grabadas a cincel fino</p>\n          </div>\n        </div>\n\n        {/* Quality Seal Certificate Block */}\n        <div className=\"mt-6 pt-6 border-t border-white/10 flex items-center gap-4 text-xs text-gray-400\">\n          <Award className=\"w-8 h-8 text-amber-500/70 flex-shrink-0\" />\n          <div>\n            <span className=\"font-semibold text-white block uppercase tracking-wide text-[10px] text-amber-500\">Sello de Certificaci\303\263n GIA Garantizada</span>\n            <p className=\"text-[11px] leading-relaxed text-gray-400 mt-0.5\">\n              Cada gema seleccionada es certificada bajo estrictos est\303\241ndares de transparencia e incluye garant\303\255a atemporal de orfebrer\303\255a firmada por nuestra Maison.\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\n// RENDER SVG JEWELRY SHAPES DYNAMICALLY WITH SHADOWS AND VECTOR FACETING\nfunction renderGemstoneShape(cut: GemstoneCut, size: number, fillUrl: string, gemColor: string) {\n  const half = size / 2;\n  \n  switch (cut) {\n    case \'Brillante\':\n      // Circular facet layout\n      return (\n        <g id=\"gem-brilliant\" className=\"animate-pulse\">\n          <circle cx=\"0\" cy=\"0\" r={half} fill={fillUrl} stroke={gemColor} strokeWidth=\"1\" />\n          {/* Facet lines */}\n          <line x1=\"0\" y1={-half} x2=\"0\" y2={half} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />\n          <line x1={-half} y1=\"0\" x2={half} y2=\"0\" stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />\n          <line x1={-half * 0.7} y1={-half * 0.7} x2={half * 0.7} y2={half * 0.7} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />\n          <line x1={-half * 0.7} y1={half * 0.7} x2={half * 0.7} y2={-half * 0.7} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />\n          {/* Star table facet inside */}\n          <polygon points={`0,${-half*0.3} ${half*0.3},0 0,${half*0.3} ${-half*0.3},0`} fill=\"white\" fillOpacity=\"0.3\" />\n        </g>\n      );\n    case \'Princesa\':\n      // Diamond Square Cut\n      return (\n        <g id=\"gem-princess\" className=\"animate-pulse\">\n          <polygon\n            points={`-${half},-${half} ${half},-${half} ${half},${half} -${half},${half}`}\n            fill={fillUrl}\n            stroke={gemColor}\n            strokeWidth=\"1.5\"\n          />\n          {/* Cross facets */}\n          <line x1={-half} y1={-half} x2={half} y2={half} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />\n          <line x1={-half} y1={half} x2={half} y2={-half} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />\n          <line x1=\"0\" y1={-half} x2=\"0\" y2={half} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.5\" />\n          <line x1={-half} y1=\"0\" x2={half} y2=\"0\" stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.5\" />\n          <rect x={-half * 0.4} y={-half * 0.4} width={size * 0.4} height={size * 0.4} fill=\"white\" fillOpacity=\"0.25\" stroke={gemColor} strokeWidth=\"0.5\" />\n        </g>\n      );\n    case \'Esmeralda\':\n      // Rectangular step cuts\n      const rectW = half * 1.3;\n      const rectH = half * 0.95;\n      return (\n        <g id=\"gem-emerald\" className=\"animate-pulse\">\n          {/* Outer Ring */}\n          <rect x={-rectW} y={-rectH} width={rectW * 2} height={rectH * 2} rx=\"2\" fill={fillUrl} stroke={gemColor} strokeWidth=\"2\" />\n          {/* Nested step facets */}\n          <rect x={-rectW * 0.75} y={-rectH * 0.75} width={rectW * 1.5} height={rectH * 1.5} rx=\"1\" fill=\"none\" stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />\n          <rect x={-rectW * 0.4} y={-rectH * 0.4} width={rectW * 0.8} height={rectH * 0.8} rx=\"0\" fill=\"none\" stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />\n          {/* Corner lines connecting steps */}\n          <line x1={-rectW} y1={-rectH} x2={-rectW * 0.4} y2={-rectH * 0.4} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.7\" />\n          <line x1={rectW} y1={-rectH} x2={rectW * 0.4} y2={-rectH * 0.4} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.7\" />\n          <line x1={rectW} y1={rectH} x2={rectW * 0.4} y2={rectH * 0.4} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.7\" />\n          <line x1={-rectW} y1={rectH} x2={-rectW * 0.4} y2={rectH * 0.4} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.7\" />\n        </g>\n      );\n    case \'Pera\':\n      // Teardrop shape path\n      const pathD = `M 0,${-half * 1.25} C ${half * 0.9},${-half * 0.2} ${half * 0.9},${half} 0,${half * 1.1} C ${-half * 0.9},${half} ${-half * 0.9},${-half * 0.2} 0,${-half * 1.25} Z`;\n      return (\n        <g id=\"gem-pear\" className=\"animate-pulse\">\n          <path d={pathD} fill={fillUrl} stroke={gemColor} strokeWidth=\"1.5\" />\n          {/* Facet radial lines from point to base */}\n          <line x1=\"0\" y1={-half * 1.25} x2=\"0\" y2={half * 1.1} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />\n          <line x1=\"0\" y1={-half * 1.25} x2={half * 0.4} y2={half * 0.4} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />\n          <line x1=\"0\" y1={-half * 1.25} x2={-half * 0.4} y2={half * 0.4} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />\n          <line x1=\"0\" y1=\"0\" x2={half * 0.7} y2={half * 0.3} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.5\" />\n          <line x1=\"0\" y1=\"0\" x2={-half * 0.7} y2={half * 0.3} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.5\" />\n        </g>\n      );\n    case \'Coj\303\255n\':\n      // Soft square rounded corners\n      const rSize = size * 0.95;\n      return (\n        <g id=\"gem-cushion\" className=\"animate-pulse\">\n          <rect x={-rSize/2} y={-rSize/2} width={rSize} height={rSize} rx={half * 0.5} fill={fillUrl} stroke={gemColor} strokeWidth=\"1.5\" />\n          {/* Faceting curves */}\n          <path d={`M0,0 M-${rSize/2},0 L${rSize/2},0 M0,-${rSize/2} L0,${rSize/2}`} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.7\" />\n          <path d={`M-${rSize/2 * 0.7},-${rSize/2 * 0.7} L${rSize/2 * 0.7},${rSize/2 * 0.7}`} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />\n          <path d={`M-${rSize/2 * 0.7},${rSize/2 * 0.7} L${rSize/2 * 0.7},-${rSize/2 * 0.7}`} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />\n          {/* Inner sparkling octagon */}\n          <polygon points={`0,-${half*0.4} ${half*0.3},-${half*0.3} ${half*0.4},0 ${half*0.3},${half*0.3} 0,${half*0.4} -${half*0.3},${half*0.3} -${half*0.4},0 -${half*0.3},-${half*0.3}`} fill=\"white\" fillOpacity=\"0.2\" />\n        </g>\n      );\n    default:\n      return null;\n  }\n}\n"
    }
