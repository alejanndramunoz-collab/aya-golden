      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\nimport { CustomJewelryDesign, JewelryType, MetalType, GemstoneType, GemstoneCut } from \'../types\';\nimport { Sparkles, Hammer, MessageSquare, Award, Sliders, Hash, Layers } from \'lucide-react\';\nimport { motion } from \'motion/react\';\n\ninterface AtelierCustomizerProps {\n  onAskStylist: (design: CustomJewelryDesign) => void;\n}\n\nconst JEWELRY_TYPES: { value: JewelryType; label: string; icon: string }[] = [\n  { value: \'Cadena\', label: \'Cadena Cubana\', icon: \'\360\237\224\227\' },\n  { value: \'Colgante\', label: \'Colgante Custom\', icon: \'\360\237\217\206\' },\n  { value: \'Anillo\', label: \'Anillo Hielo\', icon: \'\360\237\222\215\' },\n  { value: \'Brazalete\', label: \'Brazalete Tennis\', icon: \'\342\234\250\' },\n  { value: \'Grillz\', label: \'Grillz Dentales\', icon: \'\360\237\221\204\' },\n];\n\nconst METALS: { value: MetalType; label: string; bgClass: string; textClass: string; colorHex: string; glowHex: string }[] = [\n  { value: \'Oro Amarillo 14K\', label: \'Oro Amarillo 14K\', bgClass: \'bg-amber-100 border-amber-400\', textClass: \'text-amber-300\', colorHex: \'#FBBF24\', glowHex: \'rgba(251, 191, 36, 0.4)\' },\n  { value: \'Oro Blanco 14K\', label: \'Oro Blanco 14K\', bgClass: \'bg-slate-100 border-slate-300\', textClass: \'text-slate-300\', colorHex: \'#E2E8F0\', glowHex: \'rgba(226, 232, 240, 0.4)\' },\n  { value: \'Oro Rosa 14K\', label: \'Oro Rosa 14K\', bgClass: \'bg-rose-100 border-rose-300\', textClass: \'text-rose-300\', colorHex: \'#FCA5A5\', glowHex: \'rgba(252, 165, 165, 0.4)\' },\n  { value: \'Plata de Ley .925\', label: \'Plata de Ley .925\', bgClass: \'bg-zinc-200 border-zinc-400\', textClass: \'text-zinc-300\', colorHex: \'#D1D5DB\', glowHex: \'rgba(209, 213, 219, 0.3)\' },\n];\n\nconst GEMSTONES: { value: GemstoneType; label: string; colorHex: string; glowHex: string; bgClass: string; energy: string }[] = [\n  { value: \'Moissanita VVS\', label: \'Moissanita VVS\', colorHex: \'#E0F2FE\', glowHex: \'rgba(224, 242, 254, 0.8)\', bgClass: \'bg-sky-50 border-sky-200 text-sky-800\', energy: \'Brillo Extremo (Pasa Tester)\' },\n  { value: \'Circonita 5A\', label: \'Circonita Iced 5A\', colorHex: \'#FFFFFF\', glowHex: \'rgba(255, 255, 255, 0.6)\', bgClass: \'bg-gray-50 border-gray-200 text-gray-800\', energy: \'Fuego Urbano Atemporal\' },\n  { value: \'Diamante Negro\', label: \'Diamante Negro\', colorHex: \'#1E1E1E\', glowHex: \'rgba(30, 30, 30, 0.4)\', bgClass: \'bg-zinc-900 border-zinc-700 text-zinc-300\', energy: \'Autoridad & Nocturnidad\' },\n  { value: \'Rub\303\255 Lab-Grown\', label: \'Rub\303\255 Lab-Grown\', colorHex: \'#EF4444\', glowHex: \'rgba(239, 68, 68, 0.7)\', bgClass: \'bg-red-50 border-red-200 text-red-800\', energy: \'Pasi\303\263n Roja Intensa\' },\n  { value: \'Esmeralda Imperial\', label: \'Esmeralda Imperial\', colorHex: \'#10B981\', glowHex: \'rgba(16, 185, 129, 0.7)\', bgClass: \'bg-emerald-50 border-emerald-200 text-emerald-800\', energy: \'Dinast\303\255a & Abundancia\' },\n  { value: \'Ninguna\', label: \'Sin Piedras (Oro Solido)\', colorHex: \'transparent\', glowHex: \'transparent\', bgClass: \'bg-gray-100 border-gray-200 text-gray-500\', energy: \'Estilo Pulido Macizo\' },\n];\n\nconst CUTS: { value: GemstoneCut; label: string; description: string }[] = [\n  { value: \'Micro-Pave\', label: \'Micro-Pav\303\251 Hielo\', description: \'Cientos de micro-gemas engastadas para un brillo continuo\' },\n  { value: \'Prong Set\', label: \'Garras S\303\263lidas\', description: \'Piedras grandes sobresalientes que atrapan destellos masivos\' },\n  { value: \'Baguette Cut\', label: \'Baguette Ice\', description: \'Gemas rectangulares que forman bloques de hielo continuos\' },\n  { value: \'Bisel Pulido\', label: \'Borde de Oro\', description: \'Acabado minimalista liso con bordes de metal pulidos\' },\n  { value: \'Solitario\', label: \'Solitario Central\', description: \'Una gema gigantesca central custodiada por bandas heladas\' },\n];\n\nexport default function AtelierCustomizer({ onAskStylist }: AtelierCustomizerProps) {\n  const [design, setDesign] = useState<CustomJewelryDesign>({\n    type: \'Cadena\',\n    metal: \'Oro Amarillo 14K\',\n    gemstone: \'Moissanita VVS\',\n    cut: \'Micro-Pave\',\n    carats: 3.5,\n    engraving: \'AYA\',\n  });\n\n  const activeMetal = METALS.find(m => m.value === design.metal) || METALS[0];\n  const activeGem = GEMSTONES.find(g => g.value === design.gemstone) || GEMSTONES[0];\n\n  const handleTypeChange = (type: JewelryType) => {\n    setDesign(prev => ({ \n      ...prev, \n      type,\n      // Default configurations for certain styles to look best\n      cut: type === \'Grillz\' ? \'Baguette Cut\' : type === \'Cadena\' ? \'Micro-Pave\' : prev.cut\n    }));\n  };\n\n  const handleMetalChange = (metal: MetalType) => {\n    setDesign(prev => ({ ...prev, metal }));\n  };\n\n  const handleGemstoneChange = (gemstone: GemstoneType) => {\n    setDesign(prev => ({ ...prev, gemstone }));\n  };\n\n  const handleCutChange = (cut: GemstoneCut) => {\n    setDesign(prev => ({ ...prev, cut }));\n  };\n\n  const handleCaratChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    setDesign(prev => ({ ...prev, carats: parseFloat(e.target.value) }));\n  };\n\n  const handleEngravingChange = (e: React.ChangeEvent<HTMLInputElement>) => {\n    const text = e.target.value.toUpperCase().slice(0, 10); // Limit custom phrase/letter to 10 chars\n    setDesign(prev => ({ ...prev, engraving: text }));\n  };\n\n  // Base dimensions based on Carats for SVG\n  const gemSizeFactor = Math.min(Math.max(design.carats * 11, 10), 55);\n\n  return (\n    <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 text-white max-w-6xl mx-auto items-stretch animate-fade-in\" id=\"atelier-customizer\">\n      {/* LEFT: Live Interactive Preview */}\n      <div className=\"lg:col-span-5 flex flex-col justify-between bg-black/80 backdrop-blur-md rounded-2xl p-6 border border-amber-500/20 relative overflow-hidden shadow-[0_15px_40px_rgba(0,0,0,0.9)]\">\n        {/* Decorative Golden Corner Glows */}\n        <div className=\"absolute top-0 left-0 w-32 h-32 bg-amber-500/10 rounded-full filter blur-2xl pointer-events-none\" />\n        <div className=\"absolute bottom-0 right-0 w-32 h-32 bg-amber-500/10 rounded-full filter blur-2xl pointer-events-none\" />\n\n        <div className=\"flex justify-between items-center z-10\">\n          <div className=\"flex items-center gap-2\">\n            <Hammer className=\"w-4 h-4 text-amber-500\" />\n            <span className=\"text-[10px] uppercase tracking-widest font-mono text-amber-400\">LABORATORIO DE PERSONALIZACI\303\223N</span>\n          </div>\n          <span className=\"text-[9px] font-mono text-amber-500 bg-amber-500/10 border border-amber-500/20 px-2 py-0.5 rounded uppercase\">\n            ESTILO STREETWEAR\n          </span>\n        </div>\n\n        {/* Central SVG Render Engine */}\n        <div className=\"my-6 flex justify-center items-center h-64 relative z-10\">\n          {/* Glowing background ring behind gem */}\n          {design.gemstone !== \'Ninguna\' && (\n            <motion.div\n              animate={{\n                scale: [1, 1.15, 1],\n                opacity: [0.3, 0.6, 0.3],\n              }}\n              transition={{\n                duration: 3,\n                repeat: Infinity,\n                ease: \"easeInOut\",\n              }}\n              style={{\n                background: `radial-gradient(circle, ${activeGem.glowHex} 0%, transparent 70%)`,\n                width: `${gemSizeFactor * 3.5}px`,\n                height: `${gemSizeFactor * 3.5}px`,\n              }}\n              className=\"absolute rounded-full pointer-events-none\"\n            />\n          )}\n\n          <svg width=\"240\" height=\"240\" viewBox=\"0 0 200 200\" className=\"drop-shadow-[0_15px_30px_rgba(0,0,0,0.9)]\">\n            <defs>\n              <linearGradient id=\"metalLine\" x1=\"0%\" y1=\"0%\" x2=\"100%\" y2=\"100%\">\n                <stop offset=\"0%\" stopColor={activeMetal.colorHex} stopOpacity=\"0.8\" />\n                <stop offset=\"35%\" stopColor=\"#FFFFFF\" stopOpacity=\"0.95\" />\n                <stop offset=\"70%\" stopColor={activeMetal.colorHex} stopOpacity=\"0.8\" />\n                <stop offset=\"100%\" stopColor=\"#3A3018\" stopOpacity=\"0.9\" />\n              </linearGradient>\n\n              <radialGradient id=\"gemGrad\" cx=\"35%\" cy=\"35%\" r=\"65%\">\n                <stop offset=\"0%\" stopColor=\"#FFFFFF\" stopOpacity=\"0.95\" />\n                <stop offset=\"40%\" stopColor={activeGem.colorHex} stopOpacity=\"0.9\" />\n                <stop offset=\"100%\" stopColor=\"#0a0a0a\" stopOpacity=\"0.95\" />\n              </radialGradient>\n            </defs>\n\n            {/* DESIGN-SPECIFIC VECTOR RENDERING */}\n            \n            {/* 1. CADENA CUBANA (Miami Cuban Link with pave studs) */}\n            {design.type === \'Cadena\' && (\n              <g id=\"cuban-chain\" transform=\"translate(100, 100)\">\n                {/* 3 Interlocking Iced Out Cuban Links */}\n                {/* Link Left */}\n                <g transform=\"translate(-40, 0) rotate(-15)\">\n                  <rect x=\"-25\" y=\"-14\" width=\"50\" height=\"28\" rx=\"14\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"9\" />\n                  {design.gemstone !== \'Ninguna\' && renderPaveDotsOnPath(25, 14, activeGem.colorHex)}\n                </g>\n                {/* Link Right */}\n                <g transform=\"translate(40, 0) rotate(15)\">\n                  <rect x=\"-25\" y=\"-14\" width=\"50\" height=\"28\" rx=\"14\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"9\" />\n                  {design.gemstone !== \'Ninguna\' && renderPaveDotsOnPath(25, 14, activeGem.colorHex)}\n                </g>\n                {/* Center Link (Front) */}\n                <g transform=\"translate(0, 0) scale(1.15)\">\n                  <rect x=\"-25\" y=\"-14\" width=\"50\" height=\"28\" rx=\"14\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"10\" />\n                  {/* Outer shadow border */}\n                  <rect x=\"-25\" y=\"-14\" width=\"50\" height=\"28\" rx=\"14\" fill=\"none\" stroke=\"#000000\" strokeWidth=\"1.5\" strokeOpacity=\"0.4\" />\n                  {design.gemstone !== \'Ninguna\' && (\n                    <>\n                      {/* Interactive diamonds set */}\n                      {design.cut === \'Baguette Cut\' ? (\n                        // Baguettes layout\n                        <g fill={activeGem.colorHex}>\n                          <rect x=\"-18\" y=\"-3\" width=\"5\" height=\"6\" rx=\"1\" />\n                          <rect x=\"-10\" y=\"-3\" width=\"5\" height=\"6\" rx=\"1\" />\n                          <rect x=\"-2\" y=\"-3\" width=\"5\" height=\"6\" rx=\"1\" />\n                          <rect x=\"6\" y=\"-3\" width=\"5\" height=\"6\" rx=\"1\" />\n                          <rect x=\"14\" y=\"-3\" width=\"5\" height=\"6\" rx=\"1\" />\n                        </g>\n                      ) : (\n                        renderPaveDotsOnPath(25, 14, activeGem.colorHex)\n                      )}\n                    </>\n                  )}\n                </g>\n                <text x=\"0\" y=\"42\" textAnchor=\"middle\" fill=\"#888\" fontSize=\"8\" fontFamily=\"monospace\" tracking=\"2\">15MM HEAVY DRIP</text>\n              </g>\n            )}\n\n            {/* 2. COLGANTE CUSTOM (Fully iced shield with big customized word) */}\n            {design.type === \'Colgante\' && (\n              <g id=\"pendant-custom\" transform=\"translate(100, 95)\">\n                {/* Thick loop bail holding the charm */}\n                <ellipse cx=\"0\" cy=\"-55\" rx=\"12\" ry=\"18\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"8\" />\n                {design.gemstone !== \'Ninguna\' && (\n                  <g fill={activeGem.colorHex}>\n                    <circle cx=\"-6\" cy=\"-55\" r=\"2\" />\n                    <circle cx=\"0\" cy=\"-62\" r=\"2\" />\n                    <circle cx=\"6\" cy=\"-55\" r=\"2\" />\n                    <circle cx=\"0\" cy=\"-48\" r=\"2\" />\n                  </g>\n                )}\n                {/* Connector clasp */}\n                <rect x=\"-4\" y=\"-40\" width=\"8\" height=\"12\" fill=\"url(#metalLine)\" />\n\n                {/* Massive Shield/Plaque Pendant Body */}\n                <path d=\"M-45,-28 L45,-28 C45,-28 45,20 0,46 C-45,20 -45,-28 -45,-28 Z\" fill=\"url(#metalLine)\" stroke={activeMetal.colorHex} strokeWidth=\"2\" />\n                <path d=\"M-38,-22 L38,-22 C38,-22 38,15 0,38 C-38,15 -38,-22 -38,-22 Z\" fill=\"#0A0A0A\" />\n\n                {/* Iced Borders */}\n                {design.gemstone !== \'Ninguna\' && (\n                  <g fill={activeGem.colorHex} opacity=\"0.9\">\n                    {/* Top border dots */}\n                    <circle cx=\"-32\" cy=\"-22\" r=\"1.8\" className=\"animate-pulse\" />\n                    <circle cx=\"-20\" cy=\"-22\" r=\"1.8\" />\n                    <circle cx=\"-8\" cy=\"-22\" r=\"1.8\" />\n                    <circle cx=\"4\" cy=\"-22\" r=\"1.8\" />\n                    <circle cx=\"16\" cy=\"-22\" r=\"1.8\" />\n                    <circle cx=\"28\" cy=\"-22\" r=\"1.8\" />\n                    <circle cx=\"36\" cy=\"-22\" r=\"1.8\" />\n                    {/* Side curves dots */}\n                    <circle cx=\"-35\" cy=\"-8\" r=\"1.8\" />\n                    <circle cx=\"-32\" cy=\"6\" r=\"1.8\" />\n                    <circle cx=\"-24\" cy=\"18\" r=\"1.8\" />\n                    <circle cx=\"-13\" cy=\"28\" r=\"1.8\" />\n                    <circle cx=\"0\" cy=\"35\" r=\"2.2\" className=\"animate-pulse\" />\n                    <circle cx=\"13\" cy=\"28\" r=\"1.8\" />\n                    <circle cx=\"24\" cy=\"18\" r=\"1.8\" />\n                    <circle cx=\"32\" cy=\"6\" r=\"1.8\" />\n                    <circle cx=\"35\" cy=\"-8\" r=\"1.8\" />\n                  </g>\n                )}\n\n                {/* The Custom Phrase Iced Word Inside! */}\n                <text\n                  x=\"0\"\n                  y=\"6\"\n                  textAnchor=\"middle\"\n                  fill=\"#FFF\"\n                  fontSize={design.engraving.length > 5 ? \"13\" : \"18\"}\n                  fontWeight=\"900\"\n                  fontFamily=\"\'Inter\', sans-serif\"\n                  letterSpacing=\"1\"\n                  style={{\n                    textShadow: `0 0 8px ${activeGem.colorHex === \'transparent\' ? \'#FBBF24\' : activeGem.colorHex}, 0 0 15px ${activeGem.glowHex}`,\n                  }}\n                >\n                  {design.engraving || \'AYA\'}\n                </text>\n\n                {/* Optional center gemstone if solitaire selected */}\n                {design.gemstone !== \'Ninguna\' && design.cut === \'Solitario\' && (\n                  <g transform=\"translate(0, -10) scale(0.65)\">\n                    {renderGemstoneShape(\'Solitario\', gemSizeFactor, \'url(#gemGrad)\', activeGem.colorHex)}\n                  </g>\n                )}\n              </g>\n            )}\n\n            {/* 3. ANILLO HIELO (Massive iced out championship street ring) */}\n            {design.type === \'Anillo\' && (\n              <g id=\"iced-ring\" transform=\"translate(100, 105)\">\n                {/* Thick massive bottom band */}\n                <path d=\"M-40,25 C-40,55 40,55 40,25\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"15\" strokeLinecap=\"round\" />\n                <path d=\"M-36,25 L-48,-15 L48,-15 L36,25 Z\" fill=\"url(#metalLine)\" />\n\n                {/* Ring face block */}\n                <rect x=\"-42\" y=\"-28\" width=\"84\" height=\"24\" rx=\"6\" fill=\"url(#metalLine)\" stroke={activeMetal.colorHex} strokeWidth=\"1\" />\n                {/* Dark center recess */}\n                <rect x=\"-37\" y=\"-24\" width=\"74\" height=\"16\" rx=\"3\" fill=\"#0c0c0c\" />\n\n                {/* Micro pave gems on the face */}\n                {design.gemstone !== \'Ninguna\' && (\n                  <g fill={activeGem.colorHex}>\n                    {design.cut === \'Solitario\' ? (\n                      // Big single emerald/brilliant center stone\n                      <g transform=\"translate(0, -16) scale(0.7)\">\n                        {renderGemstoneShape(\'Solitario\', gemSizeFactor, \'url(#gemGrad)\', activeGem.colorHex)}\n                      </g>\n                    ) : (\n                      // Grid of Pav\303\251/Baguette ice\n                      <>\n                        <circle cx=\"-28\" cy=\"-16\" r=\"2\" />\n                        <circle cx=\"-20\" cy=\"-16\" r=\"2\" />\n                        <circle cx=\"-12\" cy=\"-16\" r=\"2\" />\n                        <circle cx=\"0\" cy=\"-16\" r=\"3.2\" className=\"animate-pulse\" />\n                        <circle cx=\"12\" cy=\"-16\" r=\"2\" />\n                        <circle cx=\"20\" cy=\"-16\" r=\"2\" />\n                        <circle cx=\"28\" cy=\"-16\" r=\"2\" />\n\n                        <circle cx=\"-24\" cy=\"-10\" r=\"1.5\" />\n                        <circle cx=\"-16\" cy=\"-10\" r=\"1.5\" />\n                        <circle cx=\"-8\" cy=\"-10\" r=\"1.5\" />\n                        <circle cx=\"0\" cy=\"-10\" r=\"2\" />\n                        <circle cx=\"8\" cy=\"-10\" r=\"1.5\" />\n                        <circle cx=\"16\" cy=\"-10\" r=\"1.5\" />\n                        <circle cx=\"24\" cy=\"-10\" r=\"1.5\" />\n                      </>\n                    )}\n                  </g>\n                )}\n\n                {/* Micro diamonds along the gold shoulders */}\n                {design.gemstone !== \'Ninguna\' && (\n                  <g fill={activeGem.colorHex} opacity=\"0.8\">\n                    <circle cx=\"-38\" cy=\"5\" r=\"1.2\" />\n                    <circle cx=\"-34\" cy=\"15\" r=\"1.2\" />\n                    <circle cx=\"38\" cy=\"5\" r=\"1.2\" />\n                    <circle cx=\"34\" cy=\"15\" r=\"1.2\" />\n                  </g>\n                )}\n              </g>\n            )}\n\n            {/* 4. BRAZALETE TENNIS (Large sparkling links) */}\n            {design.type === \'Brazalete\' && (\n              <g id=\"tennis-bracelet\" transform=\"translate(100, 100)\">\n                {/* Curved link layout */}\n                <path d=\"M-75,10 C-30,45 30,45 75,10\" fill=\"none\" stroke=\"url(#metalLine)\" strokeWidth=\"14\" strokeLinecap=\"round\" />\n                <path d=\"M-75,10 C-30,45 30,45 75,10\" fill=\"none\" stroke=\"#050505\" strokeWidth=\"10\" strokeLinecap=\"round\" />\n\n                {/* Sockets and Gems along the path */}\n                <g transform=\"translate(0,0)\">\n                  {/* Each square block contains a gemstone */}\n                  {[-60, -40, -20, 0, 20, 40, 60].map((xOffset, i) => {\n                    const yOffset = 25 - (xOffset * xOffset) / 250;\n                    return (\n                      <g key={i} transform={`translate(${xOffset}, ${yOffset})`}>\n                        {/* Gold bezel socket */}\n                        <rect x=\"-8\" y=\"-8\" width=\"16\" height=\"16\" rx=\"2\" fill=\"url(#metalLine)\" stroke={activeMetal.colorHex} strokeWidth=\"0.5\" />\n                        {design.gemstone !== \'Ninguna\' && (\n                          <circle\n                            cx=\"0\"\n                            cy=\"0\"\n                            r={design.cut === \'Prong Set\' ? \"6\" : \"4.5\"}\n                            fill={design.cut === \'Baguette Cut\' ? activeGem.colorHex : `url(#gemGrad)`}\n                            stroke={activeGem.colorHex}\n                            strokeWidth=\"0.5\"\n                            className=\"animate-pulse\"\n                            style={{\n                              fill: activeGem.colorHex,\n                            }}\n                          />\n                        )}\n                      </g>\n                    );\n                  })}\n                </g>\n                <text x=\"0\" y=\"46\" textAnchor=\"middle\" fill=\"#888\" fontSize=\"8\" fontFamily=\"monospace\" tracking=\"2\">5MM TENNIS ICE</text>\n              </g>\n            )}\n\n            {/* 5. GRILLZ DENTALES (Bespoke 6-tooth caps in heavy gold & ice baguettes) */}\n            {design.type === \'Grillz\' && (\n              <g id=\"iced-grillz\" transform=\"translate(100, 100)\">\n                {/* Gum line */}\n                <path d=\"M-65,-25 C-25,-32 25,-32 65,-25\" fill=\"none\" stroke=\"#E11D48\" strokeWidth=\"6\" strokeLinecap=\"round\" />\n                \n                {/* 6 Dental Caps */}\n                <g>\n                  {/* Left Incisor 3 */}\n                  <path d=\"M-55,-27 C-53,-27 -50,-26 -44,-26 L-47,8 C-52,8 -54,5 -57,-5 Z\" fill=\"url(#metalLine)\" stroke=\"#111\" strokeWidth=\"0.5\" />\n                  {/* Left Incisor 2 */}\n                  <path d=\"M-44,-26 C-40,-26 -37,-25 -31,-25 L-32,15 C-36,15 -39,12 -44,8 Z\" fill=\"url(#metalLine)\" stroke=\"#111\" strokeWidth=\"0.5\" />\n                  {/* Left Main Tooth 1 */}\n                  <path d=\"M-31,-25 C-25,-25 -15,-24 -11,-24 L-11,21 C-18,21 -26,20 -31,15 Z\" fill=\"url(#metalLine)\" stroke=\"#111\" strokeWidth=\"0.5\" />\n                  \n                  {/* Right Main Tooth 1 */}\n                  <path d=\"M-11,-24 C-7,-24 3,-25 9,-25 L-1,21 C-7,21 -10,21 -11,21 Z\" fill=\"url(#metalLine)\" stroke=\"#111\" strokeWidth=\"0.5\" />\n                  {/* Right Incisor 2 */}\n                  <path d=\"M9,-25 C15,-25 18,-26 22,-26 L10,15 C6,15 2,21 -1,21 Z\" fill=\"url(#metalLine)\" stroke=\"#111\" strokeWidth=\"0.5\" />\n                  {/* Right Incisor 3 */}\n                  <path d=\"M22,-26 C28,-26 31,-27 33,-27 L15,-5 C12,5 11,15 10,15 Z\" fill=\"url(#metalLine)\" stroke=\"#111\" strokeWidth=\"0.5\" />\n                </g>\n\n                {/* Overlaid sparkling gems on the teeth grill cap! */}\n                {design.gemstone !== \'Ninguna\' && (\n                  <g fill={activeGem.colorHex} opacity=\"0.95\">\n                    {/* Gem sparkles on Tooth 1 Left */}\n                    <rect x=\"-27\" y=\"-15\" width=\"4\" height=\"18\" rx=\"1\" className=\"animate-pulse\" />\n                    <rect x=\"-21\" y=\"-15\" width=\"4\" height=\"18\" rx=\"1\" />\n                    \n                    {/* Gem sparkles on Tooth 1 Right */}\n                    <rect x=\"-9\" y=\"-15\" width=\"4\" height=\"18\" rx=\"1\" />\n                    <rect x=\"-3\" y=\"-15\" width=\"4\" height=\"18\" rx=\"1\" className=\"animate-pulse\" />\n\n                    {/* Small iced pav\303\251 dots on others */}\n                    <circle cx=\"-38\" cy=\"-5\" r=\"1.5\" />\n                    <circle cx=\"-38\" cy=\"4\" r=\"1.5\" />\n                    <circle cx=\"15\" cy=\"-5\" r=\"1.5\" />\n                    <circle cx=\"15\" cy=\"4\" r=\"1.5\" />\n                  </g>\n                )}\n\n                {/* Custom engraving/engraving initials displayed below */}\n                <text x=\"0\" y=\"38\" textAnchor=\"middle\" fill=\"#FBBF24\" fontSize=\"9\" fontFamily=\"monospace\" tracking=\"2\">CUSTOM {design.engraving || \'AYA\'} MOLD</text>\n              </g>\n            )}\n          </svg>\n        </div>\n\n        {/* Info Card on Bottom of Preview */}\n        <div className=\"bg-white/5 border border-white/10 rounded-xl p-4 z-10 backdrop-blur-sm\">\n          <div className=\"flex justify-between items-start\">\n            <div>\n              <h4 className=\"text-xs font-bold uppercase tracking-wider text-white font-sans\">{design.type} de Lujo</h4>\n              <p className=\"text-[11px] text-gray-400 mt-0.5\">{design.metal} \342\200\242 {design.gemstone !== \'Ninguna\' ? `${design.gemstone} (${design.cut})` : \'Pureza de Metal Macizo\'}</p>\n            </div>\n            {design.gemstone !== \'Ninguna\' && (\n              <div className=\"text-right\">\n                <span className=\"text-[10px] px-2 py-0.5 bg-amber-500/10 text-amber-400 rounded-md border border-amber-500/20 font-mono font-bold\">\n                  {design.carats.toFixed(1)} CARAT ICE\n                </span>\n              </div>\n            )}\n          </div>\n          <div className=\"mt-3 pt-3 border-t border-white/5 flex items-center justify-between text-[10px]\">\n            <span className=\"text-gray-400 font-mono uppercase tracking-wider\">Alineaci\303\263n de Drip:</span>\n            <span className=\"text-amber-400 font-bold tracking-wide flex items-center gap-1\">\n              <Sparkles className=\"w-3 h-3 text-amber-400\" />\n              {activeGem.energy}\n            </span>\n          </div>\n        </div>\n\n        <button\n          onClick={() => onAskStylist(design)}\n          className=\"mt-4 w-full bg-gradient-to-r from-amber-500 via-yellow-600 to-amber-700 hover:from-amber-400 hover:to-amber-500 text-black py-3 px-4 rounded-xl font-bold tracking-widest text-xs uppercase shadow-lg hover:shadow-yellow-500/20 transition-all duration-300 flex items-center justify-center gap-2 z-10 active:scale-[0.98] cursor-pointer\"\n        >\n          <MessageSquare className=\"w-4 h-4 text-black fill-black\" />\n          <span>Consultar Drip (IA)</span>\n        </button>\n      </div>\n\n      {/* RIGHT: Detailed Configuration Controls */}\n      <div className=\"lg:col-span-7 flex flex-col justify-between bg-zinc-950/60 border border-white/10 rounded-2xl p-6 lg:p-8 backdrop-blur-md relative shadow-[0_15px_40px_rgba(0,0,0,0.9)]\">\n        <div className=\"space-y-6\">\n          <div className=\"flex items-center gap-2\">\n            <Sliders className=\"w-5 h-5 text-amber-500\" />\n            <h3 className=\"text-lg font-light tracking-widest text-amber-500 uppercase font-serif\">Configurador Exclusivo</h3>\n          </div>\n\n          {/* 1. Jewelry Type */}\n          <div>\n            <div className=\"flex items-center gap-2 mb-2\">\n              <Layers className=\"w-3.5 h-3.5 text-amber-400\" />\n              <label className=\"text-[10px] uppercase tracking-widest font-mono text-gray-400 block\">1. Seleccionar Estructura</label>\n            </div>\n            <div className=\"grid grid-cols-2 sm:grid-cols-5 gap-2\">\n              {JEWELRY_TYPES.map(jt => (\n                <button\n                  key={jt.value}\n                  onClick={() => handleTypeChange(jt.value)}\n                  className={`flex flex-col items-center justify-center py-2.5 px-2 rounded-xl border transition-all duration-300 cursor-pointer ${\n                    design.type === jt.value\n                      ? \'border-amber-400 bg-amber-500/10 shadow-[0_0_12px_rgba(251,191,36,0.15)] text-white\'\n                      : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                  }`}\n                >\n                  <span className=\"text-xl mb-1\">{jt.icon}</span>\n                  <span className=\"text-[10px] font-bold tracking-wide text-center leading-none\">{jt.label}</span>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* 2. Metal selection */}\n          <div>\n            <label className=\"text-[10px] uppercase tracking-widest font-mono text-gray-400 block mb-2.5\">2. Selecci\303\263n de Metal Noble</label>\n            <div className=\"grid grid-cols-2 gap-2\">\n              {METALS.map(metal => (\n                <button\n                  key={metal.value}\n                  onClick={() => handleMetalChange(metal.value)}\n                  className={`flex items-center gap-2.5 p-2.5 rounded-xl border text-left transition-all duration-300 cursor-pointer ${\n                    design.metal === metal.value\n                      ? \'border-amber-400 bg-amber-500/5 text-white\'\n                      : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                  }`}\n                >\n                  <span className={`w-4 h-4 rounded-full border ${metal.bgClass} flex-shrink-0`} />\n                  <div>\n                    <span className=\"text-xs font-bold block leading-tight\">{metal.label}</span>\n                    <span className=\"text-[9px] text-gray-500 uppercase tracking-wide font-mono\">Premium Finish</span>\n                  </div>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* 3. Gemstone selection */}\n          <div>\n            <label className=\"text-[10px] uppercase tracking-widest font-mono text-gray-400 block mb-2.5\">3. Diamantes y Gemas de Cobertura</label>\n            <div className=\"grid grid-cols-2 sm:grid-cols-3 gap-2\">\n              {GEMSTONES.map(gem => (\n                <button\n                  key={gem.value}\n                  onClick={() => handleGemstoneChange(gem.value)}\n                  className={`p-2.5 rounded-xl border text-center transition-all duration-300 flex flex-col items-center cursor-pointer ${\n                    design.gemstone === gem.value\n                      ? \'border-amber-400 bg-amber-500/10 text-white\'\n                      : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                  }`}\n                >\n                  {gem.value !== \'Ninguna\' ? (\n                    <span\n                      className=\"w-3.5 h-3.5 rounded-full mb-1 shadow-lg\"\n                      style={{\n                        backgroundColor: gem.colorHex,\n                        boxShadow: `0 0 8px ${gem.glowHex}`,\n                      }}\n                    />\n                  ) : (\n                    <span className=\"w-3.5 h-3.5 rounded-full bg-transparent border border-gray-600 mb-1\" />\n                  )}\n                  <span className=\"text-xs font-bold block leading-tight\">{gem.value}</span>\n                  <span className=\"text-[9px] text-gray-500 truncate max-w-full leading-none mt-0.5\">{gem.value === \'Ninguna\' ? \'Metal liso\' : \'Iced Drip\'}</span>\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* 4. Gemstone Cut (Setting Style) */}\n          {design.gemstone !== \'Ninguna\' && (\n            <div>\n              <label className=\"text-[10px] uppercase tracking-widest font-mono text-gray-400 block mb-2.5\">4. Tipo de Engaste e \"Iced Out\" Style</label>\n              <div className=\"grid grid-cols-1 sm:grid-cols-5 gap-2\">\n                {CUTS.map(cut => (\n                  <button\n                    key={cut.value}\n                    onClick={() => handleCutChange(cut.value)}\n                    className={`p-2 rounded-xl border text-center transition-all duration-300 flex flex-col justify-between h-16 cursor-pointer ${\n                      design.cut === cut.value\n                        ? \'border-amber-400 bg-amber-500/10 text-white\'\n                        : \'border-white/5 bg-white/5 hover:bg-white/10 text-gray-400 hover:text-white\'\n                    }`}\n                  >\n                    <span className=\"text-[10px] font-bold block leading-tight text-center w-full\">{cut.label}</span>\n                    <span className=\"text-[8px] text-gray-500 leading-none mt-1 line-clamp-2\">{cut.description}</span>\n                  </button>\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* 5. Carats (Bling Density) */}\n          {design.gemstone !== \'Ninguna\' && (\n            <div>\n              <div className=\"flex justify-between items-center mb-1\">\n                <label className=\"text-[10px] uppercase tracking-widest font-mono text-gray-400\">5. Densidad de Brillo (Grosor / Quilates)</label>\n                <span className=\"text-xs font-mono text-amber-400 font-bold bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20\">\n                  {design.carats.toFixed(2)} CT\n                </span>\n              </div>\n              <input\n                type=\"range\"\n                min=\"1.0\"\n                max=\"6.0\"\n                step=\"0.1\"\n                value={design.carats}\n                onChange={handleCaratChange}\n                className=\"w-full accent-amber-500 h-1 bg-white/10 rounded-lg cursor-pointer\"\n              />\n              <div className=\"flex justify-between text-[8px] text-gray-500 mt-1 font-mono uppercase\">\n                <span>Micro Sutil (1.0 CT)</span>\n                <span>Intermedio Drip (3.5 CT)</span>\n                <span>Heavy Bling (6.0 CT)</span>\n              </div>\n            </div>\n          )}\n\n          {/* 6. Engraving / Custom initials */}\n          <div>\n            <div className=\"flex justify-between items-center mb-1.5\">\n              <label className=\"text-[10px] uppercase tracking-widest font-mono text-gray-400\">\n                {design.type === \'Colgante\' ? \'6. Palabra / Letra Custom del Colgante\' : \'6. Grabado L\303\241ser Personalizado\'}\n              </label>\n              <span className=\"text-[9px] text-gray-500 font-mono\">Max 10 caracteres</span>\n            </div>\n            <input\n              type=\"text\"\n              value={design.engraving}\n              onChange={handleEngravingChange}\n              placeholder=\"Ej: AYA / KING / Drip\"\n              maxLength={10}\n              className=\"w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-400 focus:bg-white/10 transition-all duration-300 uppercase font-mono\"\n            />\n          </div>\n        </div>\n\n        {/* Quality Seal Certificate Block */}\n        <div className=\"mt-6 pt-6 border-t border-white/10 flex items-center gap-4 text-xs text-gray-400\">\n          <Award className=\"w-8 h-8 text-amber-500/70 flex-shrink-0\" />\n          <div>\n            <span className=\"font-bold text-white block uppercase tracking-wide text-[9px] text-amber-500 font-mono\">CERTIFICADO PASS-TESTER DE MOISSANITA</span>\n            <p className=\"text-[10px] leading-relaxed text-gray-400 mt-0.5\">\n              Todas nuestras piezas con Moissanita VVS est\303\241n garantizadas para pasar la pluma de prueba t\303\251rmica de diamantes y vienen respaldadas con tarjeta oficial de autenticidad GRA.\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n\n// Draw sparkling small diamond spots on a circular link shape\nfunction renderPaveDotsOnPath(w: number, h: number, color: string) {\n  return (\n    <g fill={color} className=\"animate-pulse\" opacity=\"0.8\">\n      {/* Top border sparkles */}\n      <circle cx=\"-16\" cy=\"-10\" r=\"1.3\" />\n      <circle cx=\"-8\" cy=\"-12\" r=\"1.3\" />\n      <circle cx=\"0\" cy=\"-12.5\" r=\"1.3\" />\n      <circle cx=\"8\" cy=\"-12\" r=\"1.3\" />\n      <circle cx=\"16\" cy=\"-10\" r=\"1.3\" />\n\n      {/* Bottom border sparkles */}\n      <circle cx=\"-16\" cy=\"10\" r=\"1.3\" />\n      <circle cx=\"-8\" cy=\"12\" r=\"1.3\" />\n      <circle cx=\"0\" cy=\"12.5\" r=\"1.3\" />\n      <circle cx=\"8\" cy=\"12\" r=\"1.3\" />\n      <circle cx=\"16\" cy=\"10\" r=\"1.3\" />\n    </g>\n  );\n}\n\n// Draw a single massive gemstone center shape\nfunction renderGemstoneShape(cut: string, size: number, fillUrl: string, gemColor: string) {\n  const half = size / 2.2;\n  return (\n    <g id=\"big-center-gem\" className=\"animate-pulse\">\n      <polygon\n        points={`0,-${half*1.3} ${half*0.9},-${half*0.5} ${half*0.9},${half*0.5} 0,${half*1.3} -${half*0.9},${half*0.5} -${half*0.9},-${half*0.5}`}\n        fill={fillUrl}\n        stroke={gemColor}\n        strokeWidth=\"1.5\"\n      />\n      {/* Brilliant faceting lines */}\n      <line x1=\"0\" y1={-half*1.3} x2=\"0\" y2={half*1.3} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />\n      <line x1={-half*0.9} y1={-half*0.5} x2={half*0.9} y2={half*0.5} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.7\" />\n      <line x1={-half*0.9} y1={half*0.5} x2={half*0.9} y2={-half*0.5} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.7\" />\n      {/* Central reflecting table */}\n      <polygon\n        points={`0,-${half*0.5} ${half*0.4},-${half*0.2} ${half*0.4},${half*0.2} 0,${half*0.5} -${half*0.4},${half*0.2} -${half*0.4},-${half*0.2}`}\n        fill=\"#FFFFFF\"\n        fillOpacity=\"0.25\"\n      />\n    </g>\n  );\n}\n"
    }
