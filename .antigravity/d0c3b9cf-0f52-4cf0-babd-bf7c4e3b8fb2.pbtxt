    replacement_chunks {
      target_content: "          <motion.div\n            initial={{ opacity: 0, y: -20 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 0.8, delay: 0.2 }}\n            className=\"flex items-center justify-center gap-2.5 text-xs tracking-[0.5em] font-mono text-amber-400 uppercase\"\n          >\n            <Sparkles className=\"w-4 h-4 text-amber-400 animate-spin-slow\" />\n            <span>Atelier de Piezas Singulares</span>\n            <Sparkles className=\"w-4 h-4 text-amber-400 animate-spin-slow\" />\n          </motion.div>\n\n          <motion.h1\n            initial={{ opacity: 0, scale: 0.96 }}\n            animate={{ opacity: 1, scale: 1 }}\n            transition={{ duration: 1.2, delay: 0.4, ease: [0.16, 1, 0.3, 1] }}\n            className=\"text-4xl sm:text-6xl md:text-7xl lg:text-8xl font-light tracking-wide text-white leading-tight font-serif\"\n          >\n            El Fulgor Eterno <br />\n            <span className=\"italic font-serif bg-gradient-to-r from-amber-200 via-yellow-400 to-amber-100 bg-clip-text text-transparent\">\n              de su Leyenda\n            </span>\n          </motion.h1>\n\n          <motion.p\n            initial={{ opacity: 0, y: 20 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 1, delay: 0.6 }}\n            className=\"text-sm sm:text-base md:text-lg text-gray-400 font-light max-w-2xl mx-auto leading-relaxed tracking-wide font-sans\"\n          >\n            Esculpimos sue\303\261os en metales nobles y constelaciones de gemas certificadas. \n            Experimente la simetr\303\255a absoluta de la alta costura orfebre and dialogue con nuestra maestra de estilo.\n          </motion.p>\n\n          <motion.div\n            initial={{ opacity: 0, y: 25 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 0.8, delay: 0.8 }}\n            className=\"pt-6 flex flex-col sm:flex-row gap-4 justify-center items-center\"\n          >\n            <button\n              onClick={() => scrollTo(\'atelier-section\')}\n              className=\"w-full sm:w-auto bg-gradient-to-r from-amber-500 via-yellow-600 to-amber-700 hover:from-amber-400 hover:to-amber-500 text-black px-8 py-3.5 rounded-xl font-medium tracking-widest text-xs uppercase shadow-lg shadow-yellow-500/10 transition-all cursor-pointer\"\n            >\n              Forjar Mi Dise\303\261o\n            </button>\n            <button\n              onClick={() => scrollTo(\'coleccion-section\')}\n              className=\"w-full sm:w-auto bg-white/5 hover:bg-white/10 border border-white/10 hover:border-amber-500/30 text-white px-8 py-3.5 rounded-xl font-medium tracking-widest text-xs uppercase transition-all cursor-pointer\"\n            >\n              Ver Tesoro Imperial\n            </button>\n          </motion.div>\n        </div>\n\n        {/* Scroll prompt */}\n        <div className=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 cursor-pointer z-20 text-gray-500 hover:text-amber-400 transition-colors duration-300\" onClick={() => scrollTo(\'atelier-section\')}>\n          <span className=\"text-[10px] tracking-[0.3em] uppercase font-mono font-light\">Descubrir</span>\n          <ChevronDown className=\"w-4 h-4 animate-bounce text-amber-500\" />\n        </div>\n      </section>\n\n      {/* SECTION 1: INTERACTIVE SIMULATION ATELIER */}\n      <section id=\"atelier-section\" className=\"py-24 sm:py-32 px-6 sm:px-8 max-w-7xl mx-auto border-t border-white/5 relative z-20 bg-black/30 rounded-t-3xl shadow-[0_-20px_40px_rgba(0,0,0,0.9)]\">\n        <div className=\"space-y-4 text-center max-w-3xl mx-auto mb-16\">\n          <span className=\"text-xs uppercase tracking-[0.4em] font-mono text-amber-500 block\">Atelier Virtual de Alta Costura</span>\n          <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white font-serif\">Simular Su Pr\303\263xima Reliquia</h2>\n          <div className=\"w-12 h-[1px] bg-amber-500 mx-auto mt-4\" />\n          <p className=\"text-sm text-gray-400 font-light leading-relaxed max-w-xl mx-auto\">\n            Moldee su visi\303\263n combinando el metal con gemas imperiales. La maestra de dise\303\261o Aurelia analizar\303\241 en tiempo real su simetr\303\255a est\303\251tica.\n          </p>\n        </div>\n\n        {/* Customized element block */}\n        <AtelierCustomizer onAskStylist={handleAskStylist} />\n      </section>\n\n      {/* SECTION 2: IMPERIAL SHOWCASE COLLECTION */}\n      <section id=\"coleccion-section\" className=\"py-24 sm:py-32 px-6 sm:px-8 max-w-7xl mx-auto border-t border-white/5 relative z-20\">\n        <div className=\"space-y-4 text-center max-w-3xl mx-auto mb-16\">\n          <span className=\"text-xs uppercase tracking-[0.4em] font-mono text-amber-500 block\">Curadur\303\255a Exclusiva de Temporada</span>\n          <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white font-serif\">La Colecci\303\263n Imperial</h2>\n          <div className=\"w-12 h-[1px] bg-amber-500 mx-auto mt-4\" />\n          <p className=\"text-sm text-gray-400 font-light leading-relaxed max-w-xl mx-auto\">\n            Explore nuestras obras maestras atemporales, forjadas por orfebres de \303\251lite bajo las fases de los solsticios m\303\241s radiantes.\n          </p>\n        </div>\n\n        <CollectionGrid \n          onLoadIntoCustomizer={handleLoadIntoCustomizer} \n          onAskStylistAboutItem={handleAskStylistAboutItem} \n        />\n      </section>"
      replacement_content: "          <motion.div\n            initial={{ opacity: 0, y: -20 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 0.8, delay: 0.2 }}\n            className=\"flex items-center justify-center gap-2.5 text-xs tracking-[0.5em] font-mono text-amber-400 uppercase\"\n          >\n            <Sparkles className=\"w-4 h-4 text-amber-400 animate-spin-slow\" />\n            <span>Laboratorio Iced Out de Alta Costura</span>\n            <Sparkles className=\"w-4 h-4 text-amber-400 animate-spin-slow\" />\n          </motion.div>\n\n          <motion.h1\n            initial={{ opacity: 0, scale: 0.96 }}\n            animate={{ opacity: 1, scale: 1 }}\n            transition={{ duration: 1.2, delay: 0.4, ease: [0.16, 1, 0.3, 1] }}\n            className=\"text-4xl sm:text-6xl md:text-7xl lg:text-8xl font-light tracking-wide text-white leading-tight font-serif\"\n          >\n            El Brillo Eterno <br />\n            <span className=\"italic font-serif bg-gradient-to-r from-amber-200 via-yellow-400 to-amber-100 bg-clip-text text-transparent\">\n              de su Estilo\n            </span>\n          </motion.h1>\n\n          <motion.p\n            initial={{ opacity: 0, y: 20 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 1, delay: 0.6 }}\n            className=\"text-sm sm:text-base md:text-lg text-gray-400 font-light max-w-2xl mx-auto leading-relaxed tracking-wide font-sans\"\n          >\n            Forjamos leyendas urbanas en Oro macizo de 14K y Moissanita VVS que pasa el detector de diamantes. \n            Experimente la simetr\303\255a absoluta de la joyer\303\255a de calle fina y dialogue con nuestra asesora de IA.\n          </motion.p>\n\n          <motion.div\n            initial={{ opacity: 0, y: 25 }}\n            animate={{ opacity: 1, y: 0 }}\n            transition={{ duration: 0.8, delay: 0.8 }}\n            className=\"pt-6 flex flex-col sm:flex-row gap-4 justify-center items-center\"\n          >\n            <button\n              onClick={() => scrollTo(\'atelier-section\')}\n              className=\"w-full sm:w-auto bg-gradient-to-r from-amber-500 via-yellow-600 to-amber-700 hover:from-amber-400 hover:to-amber-500 text-black px-8 py-3.5 rounded-xl font-medium tracking-widest text-xs uppercase shadow-lg shadow-yellow-500/10 transition-all cursor-pointer\"\n            >\n              Configurar Mi Drip\n            </button>\n            <button\n              onClick={() => scrollTo(\'coleccion-section\')}\n              className=\"w-full sm:w-auto bg-white/5 hover:bg-white/10 border border-white/10 hover:border-amber-500/30 text-white px-8 py-3.5 rounded-xl font-medium tracking-widest text-xs uppercase transition-all cursor-pointer\"\n            >\n              Ver Cat\303\241logo Iced\n            </button>\n          </motion.div>\n        </div>\n\n        {/* Scroll prompt */}\n        <div className=\"absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 cursor-pointer z-20 text-gray-500 hover:text-amber-400 transition-colors duration-300\" onClick={() => scrollTo(\'atelier-section\')}>\n          <span className=\"text-[10px] tracking-[0.3em] uppercase font-mono font-light\">Descubrir</span>\n          <ChevronDown className=\"w-4 h-4 animate-bounce text-amber-500\" />\n        </div>\n      </section>\n\n      {/* SECTION 1: INTERACTIVE SIMULATION ATELIER */}\n      <section id=\"atelier-section\" className=\"py-24 sm:py-32 px-6 sm:px-8 max-w-7xl mx-auto border-t border-white/5 relative z-20 bg-black/30 rounded-t-3xl shadow-[0_-20px_40px_rgba(0,0,0,0.9)]\">\n        <div className=\"space-y-4 text-center max-w-3xl mx-auto mb-16\">\n          <span className=\"text-xs uppercase tracking-[0.4em] font-mono text-amber-500 block\">Laboratorio Virtual de Drip</span>\n          <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white font-serif\">Dise\303\261ar Su Pr\303\263xima Pieza Iced Out</h2>\n          <div className=\"w-12 h-[1px] bg-amber-500 mx-auto mt-4\" />\n          <p className=\"text-sm text-gray-400 font-light leading-relaxed max-w-xl mx-auto\">\n            Configure su joya combinando oro de 14K con Moissanita VVS de m\303\241xima refracci\303\263n. La asesora Aurelia evaluar\303\241 el flujo de su dise\303\261o en tiempo real.\n          </p>\n        </div>\n\n        {/* Customized element block */}\n        <AtelierCustomizer onAskStylist={handleAskStylist} />\n      </section>\n\n      {/* SECTION 2: IMPERIAL SHOWCASE COLLECTION */}\n      <section id=\"coleccion-section\" className=\"py-24 sm:py-32 px-6 sm:px-8 max-w-7xl mx-auto border-t border-white/5 relative z-20\">\n        <div className=\"space-y-4 text-center max-w-3xl mx-auto mb-16\">\n          <span className=\"text-xs uppercase tracking-[0.4em] font-mono text-amber-500 block\">Lanzamientos Exclusivos de Temporada</span>\n          <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white font-serif\">El Cat\303\241logo Iced Out</h2>\n          <div className=\"w-12 h-[1px] bg-amber-500 mx-auto mt-4\" />\n          <p className=\"text-sm text-gray-400 font-light leading-relaxed max-w-xl mx-auto\">\n            Explore nuestras obras maestras heladas, forjadas por orfebres legendarios para liderar la vanguardia de la cultura urbana.\n          </p>\n        </div>\n\n        <CollectionGrid \n          onLoadIntoCustomizer={handleLoadIntoCustomizer} \n          onAskStylistAboutItem={handleAskStylistAboutItem} \n        />\n      </section>"
    }
