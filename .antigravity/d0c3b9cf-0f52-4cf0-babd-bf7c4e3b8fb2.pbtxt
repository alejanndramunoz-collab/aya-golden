    replacement_infos {
      original_chunk {
        target_content: "        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          <div className=\"lg:col-span-5 space-y-6\">\n            <span className=\"text-xs uppercase tracking-[0.3em] font-mono text-amber-500 block\">Compromiso \303\211tico e Imperecedero</span>\n            <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white leading-tight font-serif\">El Respeto Absoluto al Origen</h2>\n            <div className=\"w-12 h-[1px] bg-amber-500\" />\n            <p className=\"text-sm text-gray-300 font-light leading-relaxed\">\n              En AURA Haute Joaillerie, creemos que la belleza de una gema no radica \303\272nicamente en su refracci\303\263n de luz, sino en la pureza de su trayecto hasta sus manos. \n              Garantizamos diamantes libres de conflictos y oro recolectado bajo protocolos de sustentabilidad total.\n            </p>\n            <div className=\"space-y-3 pt-4\">\n              <div className=\"flex items-start gap-3\">\n                <div className=\"w-6 h-6 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 mt-0.5\">\n                  <ShieldCheck className=\"w-3.5 h-3.5 text-amber-400\" />\n                </div>\n                <div>\n                  <span className=\"text-xs font-semibold text-white block\">Certificaci\303\263n del Kimberley Process</span>\n                  <span className=\"text-[11px] text-gray-400\">Cada diamante se rastrea desde la mina oficial respetando los derechos de las comunidades locales.</span>\n                </div>\n              </div>\n              <div className=\"flex items-start gap-3\">\n                <div className=\"w-6 h-6 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 mt-0.5\">\n                  <Award className=\"w-3.5 h-3.5 text-amber-400\" />\n                </div>\n                <div>\n                  <span className=\"text-xs font-semibold text-white block\">Metales Fairmined Garantizados</span>\n                  <span className=\"text-[11px] text-gray-400\">Soportamos directamente la miner\303\255a artesanal \303\251tica y responsable libre de agentes mercuriales nocivos.</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-7 grid grid-cols-2 gap-4\">\n            <div className=\"space-y-4\">\n              <div className=\"rounded-2xl overflow-hidden aspect-[4/5] bg-zinc-950 border border-white/5 relative group\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?auto=format&fit=crop&q=80&w=800\" \n                  alt=\"Crafting diamond\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\"\n                />\n                <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" />\n                <span className=\"absolute bottom-4 left-4 text-xs font-mono text-amber-400 uppercase tracking-widest\">Orfebrer\303\255a Cincelada</span>\n              </div>\n              <div className=\"rounded-2xl bg-gradient-to-br from-amber-500/10 to-transparent border border-amber-500/10 p-6 space-y-2\">\n                <h4 className=\"text-lg font-serif font-light text-amber-400\">100+ Horas</h4>\n                <p className=\"text-xs text-gray-400 leading-relaxed\">De dedicaci\303\263n manual absoluta invertida por pieza por orfebres con maestr\303\255a heredada.</p>\n              </div>\n            </div>\n            \n            <div className=\"space-y-4 pt-8\">\n              <div className=\"rounded-2xl bg-zinc-900/40 border border-white/5 p-6 space-y-2\">\n                <h4 className=\"text-lg font-serif font-light text-amber-400\">GIA Superior</h4>\n                <p className=\"text-xs text-gray-400 leading-relaxed\">Evaluaci\303\263n rigurosa bajo el laboratorio gemol\303\263gico m\303\241s estricto del globo terrestre.</p>\n              </div>\n              <div className=\"rounded-2xl overflow-hidden aspect-[4/5] bg-zinc-950 border border-white/5 relative group\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1617038260897-41a1f14a8ca0?auto=format&fit=crop&q=80&w=800\" \n                  alt=\"Finished masterpiece\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\"\n                />\n                <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" />\n                <span className=\"absolute bottom-4 left-4 text-xs font-mono text-amber-400 uppercase tracking-widest\">Reliquias Imperiales</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* LUXURY EMBELLISHED FOOTER */}\n      <footer className=\"bg-black py-16 px-6 sm:px-8 border-t border-white/10 relative z-20 text-gray-400\">\n        <div className=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-8 items-start mb-12\">\n          {/* Logo brand info column */}\n          <div className=\"md:col-span-5 space-y-4 text-center md:text-left\">\n            <h3 className=\"text-2xl font-light tracking-widest text-white font-serif\">Maison AYA GOLDEN</h3>\n            <p className=\"text-xs text-gray-400 font-light leading-relaxed max-w-sm mx-auto md:mx-0\">\n              Inspirados en la geometr\303\255a celeste y la orfebrer\303\255a imperial de Par\303\255s, forjamos piezas singulares de belleza imperecedera.\n            </p>\n            <div className=\"pt-2 text-xs font-mono text-amber-500/70 tracking-widest\">\n              PAR\303\215S \342\200\242 GINEBRA \342\200\242 TOKIO\n            </div>\n          </div>\n\n          {/* Links column */}\n          <div className=\"md:col-span-3 space-y-2 text-center md:text-left\">\n            <h4 className=\"text-xs font-semibold tracking-wider text-white uppercase font-mono\">Navegaci\303\263n</h4>\n            <ul className=\"text-xs space-y-2 font-light\">\n              <li><button onClick={() => window.scrollTo({ top: 0, behavior: \'smooth\' })} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Volver al Firmamento</button></li>\n              <li><button onClick={() => scrollTo(\'atelier-section\')} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Atelier Simulador</button></li>\n              <li><button onClick={() => scrollTo(\'coleccion-section\')} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Cat\303\241logo Imperial</button></li>\n            </ul>\n          </div>\n\n          {/* Contact coordinates column */}\n          <div className=\"md:col-span-4 space-y-2 text-center md:text-left\">\n            <h4 className=\"text-xs font-semibold tracking-wider text-white uppercase font-mono\">Atenci\303\263n Exclusiva</h4>\n            <ul className=\"text-xs space-y-1.5 font-light\">\n              <li className=\"text-amber-500 font-medium\">salon@ayagolden-joaillerie.com</li>\n              <li>Place Vend\303\264me 14, 75001 Par\303\255s, Francia</li>\n              <li className=\"text-[10px] text-gray-500 pt-1 font-mono\">Horario del Taller: Lunes a S\303\241bado de 10:00 a 19:00 (CET)</li>\n            </ul>\n          </div>\n        </div>\n\n        {/* Bottom copyright declaration */}\n        <div className=\"max-w-7xl mx-auto pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center text-[11px] text-gray-600 gap-4\">\n          <p>\302\251 {new Date().getFullYear()} AYA GOLDEN Joyer\303\255a. Todos los derechos reservados. Miembro del Sindicato de Alta Orfebrer\303\255a.</p>\n          <div className=\"flex gap-4 font-mono uppercase tracking-wider text-[10px]\">\n            <span className=\"hover:text-gray-400 transition-colors cursor-pointer\">Seguridad GIA</span>\n            <span>\342\200\242</span>\n            <span className=\"hover:text-gray-400 transition-colors cursor-pointer\">Sello de Sustentabilidad</span>\n          </div>\n        </div>\n      </footer>"
        replacement_content: "        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-center\">\n          <div className=\"lg:col-span-5 space-y-6\">\n            <span className=\"text-xs uppercase tracking-[0.3em] font-mono text-amber-500 block\">Sello de Calidad e Iced Out Real</span>\n            <h2 className=\"text-3xl sm:text-4xl md:text-5xl font-light tracking-wide text-white leading-tight font-serif\">Garant\303\255a de Moissanita VVS</h2>\n            <div className=\"w-12 h-[1px] bg-amber-500\" />\n            <p className=\"text-sm text-gray-300 font-light leading-relaxed\">\n              En AYA GOLDEN, el brillo glacial va de la mano con la pureza f\303\255sica y estructural de cada pieza. \n              Nuestras Moissanitas VVS de m\303\241xima refracci\303\263n est\303\241n dise\303\261adas para reflejar la luz con una intensidad incomparable, pasando con \303\251xito el detector de diamantes t\303\251rmico.\n            </p>\n            <div className=\"space-y-3 pt-4\">\n              <div className=\"flex items-start gap-3\">\n                <div className=\"w-6 h-6 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 mt-0.5\">\n                  <ShieldCheck className=\"w-3.5 h-3.5 text-amber-400\" />\n                </div>\n                <div>\n                  <span className=\"text-xs font-semibold text-white block\">Garant\303\255a Pass-Tester y Certificaci\303\263n GRA</span>\n                  <span className=\"text-[11px] text-gray-400\">Cada moissanita se entrega con su n\303\272mero de reporte GRA grabado a l\303\241ser en el filet de la gema, garantizando su autenticidad y corte sim\303\251trico.</span>\n                </div>\n              </div>\n              <div className=\"flex items-start gap-3\">\n                <div className=\"w-6 h-6 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 mt-0.5\">\n                  <Award className=\"w-3.5 h-3.5 text-amber-400\" />\n                </div>\n                <div>\n                  <span className=\"text-xs font-semibold text-white block\">Metales S\303\263lidos y Pesados</span>\n                  <span className=\"text-[11px] text-gray-400\">Evitamos ba\303\261os de oro delgados. Nuestras joyas est\303\241n forjadas sobre Plata de Ley .925 maciza o fundidas en Oro de 14K s\303\263lido con un peso premium.</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"lg:col-span-7 grid grid-cols-2 gap-4\">\n            <div className=\"space-y-4\">\n              <div className=\"rounded-2xl overflow-hidden aspect-[4/5] bg-zinc-950 border border-white/5 relative group\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?auto=format&fit=crop&q=80&w=800\" \n                  alt=\"Crafting diamond\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\"\n                />\n                <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" />\n                <span className=\"absolute bottom-4 left-4 text-xs font-mono text-amber-400 uppercase tracking-widest\">Orfebrer\303\255a Iced Out</span>\n              </div>\n              <div className=\"rounded-2xl bg-gradient-to-br from-amber-500/10 to-transparent border border-amber-500/10 p-6 space-y-2\">\n                <h4 className=\"text-lg font-serif font-light text-amber-400\">80+ Horas</h4>\n                <p className=\"text-xs text-gray-400 leading-relaxed\">De engaste manual microm\303\251trico invertido por cada maestro artesano para asegurar que ninguna piedra se caiga jam\303\241s.</p>\n              </div>\n            </div>\n            \n            <div className=\"space-y-4 pt-8\">\n              <div className=\"rounded-2xl bg-zinc-900/40 border border-white/5 p-6 space-y-2\">\n                <h4 className=\"text-lg font-serif font-light text-amber-400\">Moissanita VVS1</h4>\n                <p className=\"text-xs text-gray-400 leading-relaxed\">M\303\241xima refracci\303\263n y fuego de luz que supera al diamante natural bajo cualquier flash o foco de escenario.</p>\n              </div>\n              <div className=\"rounded-2xl overflow-hidden aspect-[4/5] bg-zinc-950 border border-white/5 relative group\">\n                <img \n                  src=\"https://images.unsplash.com/photo-1617038260897-41a1f14a8ca0?auto=format&fit=crop&q=80&w=800\" \n                  alt=\"Finished masterpiece\" \n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\"\n                />\n                <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent\" />\n                <span className=\"absolute bottom-4 left-4 text-xs font-mono text-amber-400 uppercase tracking-widest\">Obras de Arte Urbanas</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* LUXURY EMBELLISHED FOOTER */}\n      <footer className=\"bg-black py-16 px-6 sm:px-8 border-t border-white/10 relative z-20 text-gray-400\">\n        <div className=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-8 items-start mb-12\">\n          {/* Logo brand info column */}\n          <div className=\"md:col-span-5 space-y-4 text-center md:text-left\">\n            <h3 className=\"text-2xl font-light tracking-widest text-white font-serif\">Maison AYA GOLDEN</h3>\n            <p className=\"text-xs text-gray-400 font-light leading-relaxed max-w-sm mx-auto md:mx-0\">\n              L\303\255deres en la alta joyer\303\255a urbana y el streetwear de lujo. Forjamos el drip que define generaciones, uniendo la precisi\303\263n de la orfebrer\303\255a fina con la cultura hip-hop de \303\251lite.\n            </p>\n            <div className=\"pt-2 text-xs font-mono text-amber-500/70 tracking-widest\">\n              LOS \303\201NGELES \342\200\242 MIL\303\201N \342\200\242 TOKIO\n            </div>\n          </div>\n\n          {/* Links column */}\n          <div className=\"md:col-span-3 space-y-2 text-center md:text-left\">\n            <h4 className=\"text-xs font-semibold tracking-wider text-white uppercase font-mono\">Navegaci\303\263n</h4>\n            <ul className=\"text-xs space-y-2 font-light\">\n              <li><button onClick={() => window.scrollTo({ top: 0, behavior: \'smooth\' })} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Volver al Inicio</button></li>\n              <li><button onClick={() => scrollTo(\'atelier-section\')} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Atelier Iced</button></li>\n              <li><button onClick={() => scrollTo(\'coleccion-section\')} className=\"hover:text-amber-400 cursor-pointer transition-colors\">Cat\303\241logo Iced</button></li>\n            </ul>\n          </div>\n\n          {/* Contact coordinates column */}\n          <div className=\"md:col-span-4 space-y-2 text-center md:text-left\">\n            <h4 className=\"text-xs font-semibold tracking-wider text-white uppercase font-mono\">Atenci\303\263n Exclusiva</h4>\n            <ul className=\"text-xs space-y-1.5 font-light\">\n              <li className=\"text-amber-500 font-medium\">vip@ayagolden.com</li>\n              <li>Melrose Avenue 8420, West Hollywood, Los \303\201ngeles, CA</li>\n              <li className=\"text-[10px] text-gray-500 pt-1 font-mono\">Horario de Taller: Lunes a S\303\241bado de 10:00 a 20:00 (PST)</li>\n            </ul>\n          </div>\n        </div>\n\n        {/* Bottom copyright declaration */}\n        <div className=\"max-w-7xl mx-auto pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center text-[11px] text-gray-600 gap-4\">\n          <p>\302\251 {new Date().getFullYear()} AYA GOLDEN Joyer\303\255a. Todos los derechos reservados. Miembro de la Alianza de Alta Orfebrer\303\255a Urbana.</p>\n          <div className=\"flex gap-4 font-mono uppercase tracking-wider text-[10px]\">\n            <span className=\"hover:text-gray-400 transition-colors cursor-pointer\">Certificaci\303\263n GRA</span>\n            <span>\342\200\242</span>\n            <span className=\"hover:text-gray-400 transition-colors cursor-pointer\">Sello de Sustentabilidad</span>\n          </div>\n        </div>\n      </footer>"
      }
      num_matches: 1
    }
  }
}
