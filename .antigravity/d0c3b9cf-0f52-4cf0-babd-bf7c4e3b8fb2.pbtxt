      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState, useRef, useEffect } from \'react\';\nimport { ChatMessage, CustomJewelryDesign } from \'../types\';\nimport { Send, Sparkles, MessageSquare, Bot, User, X, Landmark, Compass, HelpCircle } from \'lucide-react\';\nimport { motion, AnimatePresence } from \'motion/react\';\n\ninterface AIStylistProps {\n  currentDesign: CustomJewelryDesign | null;\n  onClearDesign: () => void;\n  isOpen: boolean;\n  onClose: () => void;\n}\n\nconst PRESETS = [\n  { label: \'\360\237\224\256 Significado m\303\255stico\', query: \'\302\277Podr\303\255as contarme la leyenda espiritual y energ\303\255a m\303\255stica de la gema seleccionada?\' },\n  { label: \'\360\237\221\227 Gu\303\255a de gala y maridaje\', query: \'\302\277C\303\263mo me recomiendas vestir y lucir esta pieza? \302\277Qu\303\251 tipo de gala o vestido combina?\' },\n  { label: \'\342\232\234\357\270\217 Pareja y complementos\', query: \'\302\277Qu\303\251 otra joya de la colecci\303\263n imperial har\303\255a la pareja perfecta con mi creaci\303\263n?\' },\n  { label: \'\360\237\247\252 Certificaci\303\263n e historia\', query: \'H\303\241blame de los est\303\241ndares de pureza y la historia de la orfebrer\303\255a francesa del metal noble de mi joya.\' },\n];\n\nexport default function AIStylist({ currentDesign, onClearDesign, isOpen, onClose }: AIStylistProps) {\n  const [messages, setMessages] = useState<ChatMessage[]>([\n    {\n      id: \'init-1\',\n      sender: \'stylist\',\n      text: \'Bienvenido al sal\303\263n de dise\303\261o de AURA Joyer\303\255a. Soy Aurelia, su guardiana est\303\251tica en este santuario de orfebrer\303\255a fina. Cu\303\251nteme, \302\277cu\303\241l es el deseo que anhela materializar hoy? Si est\303\241 simulando una pieza, podr\303\251 aconsejarle sobre su armon\303\255a crom\303\241tica, su legado m\303\255stico y el vestuario ideal para lucirla con distinci\303\263n absoluta.\',\n      timestamp: new Date().toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\' }),\n      isInitial: true,\n    }\n  ]);\n  const [input, setInput] = useState(\'\');\n  const [isLoading, setIsLoading] = useState(false);\n  const messagesEndRef = useRef<HTMLDivElement>(null);\n\n  useEffect(() => {\n    scrollToBottom();\n  }, [messages, isLoading]);\n\n  const scrollToBottom = () => {\n    messagesEndRef.current?.scrollIntoView({ behavior: \'smooth\' });\n  };\n\n  const handleSend = async (textToSend: string) => {\n    if (!textToSend.trim() || isLoading) return;\n\n    const userMsg: ChatMessage = {\n      id: `user-${Date.now()}`,\n      sender: \'user\',\n      text: textToSend,\n      timestamp: new Date().toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\' }),\n    };\n\n    setMessages(prev => [...prev, userMsg]);\n    setInput(\'\');\n    setIsLoading(true);\n\n    try {\n      const response = await fetch(\'/api/stylist/chat\', {\n        method: \'POST\',\n        headers: {\n          \'Content-Type\': \'application/json\',\n        },\n        body: JSON.stringify({\n          message: textToSend,\n          currentDesign: currentDesign,\n        }),\n      });\n\n      if (!response.ok) {\n        throw new Error(\'No se pudo conectar con el Atelier de IA.\');\n      }\n\n      const data = await response.json();\n      \n      const stylistMsg: ChatMessage = {\n        id: `stylist-${Date.now()}`,\n        sender: \'stylist\',\n        text: data.text || \'Mis disculpas, querido cliente. He perdido moment\303\241neamente la visi\303\263n crom\303\241tica del metal. Por favor, reformule su magn\303\255fica pregunta.\',\n        timestamp: new Date().toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\' }),\n      };\n\n      setMessages(prev => [...prev, stylistMsg]);\n    } catch (error) {\n      console.error(\'Error communicating with AI Stylist:\', error);\n      \n      const errorMsg: ChatMessage = {\n        id: `stylist-err-${Date.now()}`,\n        sender: \'stylist\',\n        text: \'Mis disculpas, querido cliente. He perdido moment\303\241neamente la visi\303\263n crom\303\241tica de nuestro taller. De todos modos, tenga la certeza de que su creaci\303\263n es divina. \302\277Podemos reintentar nuestro di\303\241logo?\',\n        timestamp: new Date().toLocaleTimeString([], { hour: \'2-digit\', minute: \'2-digit\' }),\n      };\n      \n      setMessages(prev => [...prev, errorMsg]);\n    } finally {\n      setIsLoading(false);\n    }\n  };\n\n  return (\n    <AnimatePresence>\n      {isOpen && (\n        <motion.div\n          initial={{ opacity: 0, x: 100 }}\n          animate={{ opacity: 1, x: 0 }}\n          exit={{ opacity: 0, x: 100 }}\n          transition={{ duration: 0.4, ease: [0.16, 1, 0.3, 1] }}\n          className=\"fixed right-0 top-0 bottom-0 w-full sm:w-[480px] bg-zinc-950/95 border-l border-amber-500/20 shadow-[0_0_50px_rgba(0,0,0,0.9)] z-50 flex flex-col justify-between text-white backdrop-blur-xl\"\n        >\n          {/* Header */}\n          <div className=\"p-4 border-b border-white/10 flex justify-between items-center bg-black/40\">\n            <div className=\"flex items-center gap-2.5\">\n              <div className=\"w-9 h-9 rounded-full bg-gradient-to-tr from-amber-500 to-yellow-300 flex items-center justify-center shadow-lg relative\">\n                <Sparkles className=\"w-5 h-5 text-black\" />\n                <span className=\"absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-500 border border-black rounded-full\" />\n              </div>\n              <div>\n                <h3 className=\"text-sm font-semibold tracking-wider text-amber-400 uppercase font-sans\">Aurelia \342\200\242 Estilista IA</h3>\n                <p className=\"text-[10px] text-gray-400 font-mono tracking-widest uppercase\">Maison d\\\'Orfevrerie</p>\n              </div>\n            </div>\n            \n            <button\n              onClick={onClose}\n              className=\"w-8 h-8 rounded-full bg-white/5 hover:bg-white/10 flex items-center justify-center transition-all duration-200 border border-white/5 hover:border-white/25 cursor-pointer\"\n            >\n              <X className=\"w-4 h-4 text-gray-400 hover:text-white\" />\n            </button>\n          </div>\n\n          {/* Sub-Header: Active design badge if loaded */}\n          {currentDesign && (\n            <div className=\"bg-amber-500/10 px-4 py-2 border-b border-amber-500/20 flex justify-between items-center text-xs\">\n              <div className=\"flex items-center gap-2 text-amber-300\">\n                <span className=\"animate-ping w-1.5 h-1.5 bg-amber-400 rounded-full flex-shrink-0\" />\n                <span className=\"font-medium tracking-wide\">\n                  Dise\303\261o adjunto: <strong className=\"font-semibold\">{currentDesign.type} ({currentDesign.gemstone})</strong>\n                </span>\n              </div>\n              <button\n                onClick={onClearDesign}\n                className=\"text-[10px] uppercase font-mono tracking-wider text-amber-500 hover:text-amber-300 transition-colors cursor-pointer\"\n              >\n                Liberar\n              </button>\n            </div>\n          )}\n\n          {/* Messages Area */}\n          <div className=\"flex-1 overflow-y-auto p-4 space-y-4 scrollbar-thin scrollbar-thumb-white/10\">\n            {messages.map(msg => (\n              <div\n                key={msg.id}\n                className={`flex gap-3 max-w-[85%] ${msg.sender === \'user\' ? \'ml-auto flex-row-reverse\' : \'mr-auto\'}`}\n              >\n                <div\n                  className={`w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 text-xs border ${\n                    msg.sender === \'user\'\n                      ? \'bg-zinc-800 border-zinc-700 text-gray-300\'\n                      : \'bg-amber-950/50 border-amber-500/30 text-amber-400\'\n                  }`}\n                >\n                  {msg.sender === \'user\' ? <User className=\"w-3.5 h-3.5\" /> : <Bot className=\"w-3.5 h-3.5\" />}\n                </div>\n\n                <div className=\"space-y-1\">\n                  <div\n                    className={`rounded-2xl px-4 py-3 text-sm leading-relaxed ${\n                      msg.sender === \'user\'\n                        ? \'bg-amber-500 text-black font-medium selection:bg-amber-800 selection:text-white shadow-md\'\n                        : \'bg-white/5 border border-white/10 text-gray-200\'\n                    }`}\n                  >\n                    <p className=\"whitespace-pre-line font-light tracking-wide\">{msg.text}</p>\n                  </div>\n                  <span className=\"text-[9px] text-gray-500 block px-2 text-right\">\n                    {msg.timestamp}\n                  </span>\n                </div>\n              </div>\n            ))}\n\n            {/* AI thinking indicator */}\n            {isLoading && (\n              <div className=\"flex gap-3 max-w-[85%] mr-auto items-center\">\n                <div className=\"w-7 h-7 rounded-full bg-amber-950/50 border border-amber-500/30 text-amber-400 flex items-center justify-center\">\n                  <Bot className=\"w-3.5 h-3.5 animate-spin\" />\n                </div>\n                <div className=\"bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-xs text-amber-400/80 tracking-widest uppercase font-mono animate-pulse\">\n                  Aurelia esculpe su consejo est\303\251tico...\n                </div>\n              </div>\n            )}\n            \n            <div ref={messagesEndRef} />\n          </div>\n\n          {/* Presets and Suggestion Section */}\n          <div className=\"p-3 bg-black/40 border-t border-white/10 space-y-2\">\n            <span className=\"text-[9px] uppercase tracking-widest font-mono text-gray-500 block px-1\">\n              Consultas sugeridas de alta costura:\n            </span>\n            <div className=\"flex flex-wrap gap-1.5 max-h-24 overflow-y-auto pr-1\">\n              {PRESETS.map((preset, index) => (\n                <button\n                  key={index}\n                  onClick={() => handleSend(preset.query)}\n                  disabled={isLoading}\n                  className=\"text-[10px] text-gray-400 hover:text-white bg-white/5 hover:bg-amber-500/10 border border-white/5 hover:border-amber-500/30 px-2 py-1 rounded-full transition-all duration-200 truncate max-w-full cursor-pointer disabled:opacity-50\"\n                >\n                  {preset.label}\n                </button>\n              ))}\n            </div>\n          </div>\n\n          {/* Chat input form */}\n          <form\n            onSubmit={(e) => {\n              e.preventDefault();\n              handleSend(input);\n            }}\n            className=\"p-4 border-t border-white/10 bg-black/60 flex items-center gap-2\"\n          >\n            <input\n              type=\"text\"\n              value={input}\n              onChange={(e) => setInput(e.target.value)}\n              placeholder=\"Describa su visi\303\263n de lujo o pregunte...\"\n              disabled={isLoading}\n              className=\"flex-1 bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-sm text-white placeholder-gray-500 focus:outline-none focus:border-amber-400 focus:bg-white/10 transition-all duration-300 disabled:opacity-50\"\n            />\n            <button\n              type=\"submit\"\n              disabled={!input.trim() || isLoading}\n              className=\"w-11 h-11 rounded-xl bg-amber-500 hover:bg-amber-400 text-black flex items-center justify-center shadow-lg hover:shadow-yellow-500/20 active:scale-95 transition-all duration-200 disabled:opacity-50 disabled:bg-zinc-800 disabled:text-zinc-600 disabled:shadow-none cursor-pointer\"\n            >\n              <Send className=\"w-4 h-4 text-inherit\" />\n            </button>\n          </form>\n        </motion.div>\n      )}\n    </AnimatePresence>\n  );\n}\n"
    }
