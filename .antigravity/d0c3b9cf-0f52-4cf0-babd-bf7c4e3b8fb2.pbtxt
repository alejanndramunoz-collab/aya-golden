      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport { CollectionItem } from \'./types\';\n\nexport const EXQUISITE_COLLECTION: CollectionItem[] = [\n  {\n    id: \'coll-1\',\n    name: \'L\\\'\303\211clat \303\211ternel\',\n    type: \'Collar\',\n    description: \'Un majestuoso collar de gala en platino puro, coronado por un diamante de claridad insuperable tallado a mano.\',\n    price: \'\342\202\254142,000\',\n    image: \'https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Platino\',\n    gemstone: \'Diamante\',\n    cut: \'Brillante\',\n    story: \'Forjado en conmemoraci\303\263n del solsticio c\303\263smico. Su dise\303\261o sim\303\251trico simboliza la uni\303\263n indestructible entre la luz eterna del firmamento y la sobria distinci\303\263n de la tierra.\',\n    specs: {\n      weight: \'4.8 Quilates\',\n      clarity: \'FL (Flawless)\',\n      origin: \'Atelier Place Vend\303\264me, Par\303\255s\'\n    }\n  },\n  {\n    id: \'coll-2\',\n    name: \'L\\\'\303\211meraude Royale\',\n    type: \'Anillo\',\n    description: \'Anillo tallado en Oro Amarillo de 18 quilates, engastado con una esmeralda colombiana de refracci\303\263n aterciopelada.\',\n    price: \'\342\202\25488,000\',\n    image: \'https://images.unsplash.com/photo-1605100804763-247f67b3557e?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Amarillo 18K\',\n    gemstone: \'Esmeralda\',\n    cut: \'Esmeralda\',\n    story: \'Inspirado en los m\303\255ticos jardines suspendidos de Babilonia. El profundo verde esmeralda evoca el renacimiento espiritual de la primavera imperial y los secretos de soberanas antiguas.\',\n    specs: {\n      weight: \'3.5 Quilates\',\n      clarity: \'VVS1 (Very Very Slightly Included)\',\n      origin: \'Minas de Muzo, Colombia\'\n    }\n  },\n  {\n    id: \'coll-3\',\n    name: \'Larmes du Cosmos\',\n    type: \'Pendientes\',\n    description: \'Pendientes flotantes esculpidos en Oro Blanco, decorados con zafiros de Ceyl\303\241n en exquisita talla pera.\',\n    price: \'\342\202\25465,000\',\n    image: \'https://images.unsplash.com/photo-1535632066927-ab7c9ab60908?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Blanco 18K\',\n    gemstone: \'Zafiro\',\n    cut: \'Pera\',\n    story: \'Se cuenta que el azul m\303\255stico del zafiro de Ceyl\303\241n absorbe la energ\303\255a del oc\303\251ano primordial. Dise\303\261ado para danzar con el viento del crep\303\272sculo y reflejar las velas nocturnas.\',\n    specs: {\n      weight: \'5.2 Quilates total\',\n      clarity: \'IF (Internally Flawless)\',\n      origin: \'Ceyl\303\241n (Sri Lanka)\'\n    }\n  },\n  {\n    id: \'coll-4\',\n    name: \'Le Sceptre d\\\'Or\',\n    type: \'Brazalete\',\n    description: \'Brazalete r\303\255gido de Oro Rosa con incrustaciones de rub\303\255es sangre de pich\303\263n cortados en simetr\303\255a perfecta.\',\n    price: \'\342\202\254115,000\',\n    image: \'https://images.unsplash.com/photo-1617038260897-41a1f14a8ca0?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Rosa 18K\',\n    gemstone: \'Rub\303\255\',\n    cut: \'Princesa\',\n    story: \'El rub\303\255 encarna la pasi\303\263n imperiosa, la fuerza vital y el coraje inquebrantable de dinast\303\255as pasadas. Esta pieza requiere m\303\241s de cien horas de detallada orfebrer\303\255a de precisi\303\263n.\',\n    specs: {\n      weight: \'6.0 Quilates total\',\n      clarity: \'VVS2\',\n      origin: \'Regi\303\263n de Mogok, Myanmar\'\n    }\n  },\n  {\n    id: \'coll-5\',\n    name: \'Aura d\\\'Am\303\251thyste\',\n    type: \'Anillo\',\n    description: \'Una amatista m\303\255stica tallada en coj\303\255n, engarzada majestuosamente en finos filamentos trenzados de Oro Rosa.\',\n    price: \'\342\202\25442,000\',\n    image: \'https://images.unsplash.com/photo-1602751584552-8ba73aad10e1?auto=format&fit=crop&q=80&w=1200\',\n    metal: \'Oro Rosa 18K\',\n    