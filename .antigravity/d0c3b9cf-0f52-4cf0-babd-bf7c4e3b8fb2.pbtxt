          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "function renderGemstoneShape(cut: GemstoneCut, size: number, fillUrl: string, gemColor: string) {"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "  const half = size / 2;"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "  switch (cut) {"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "    case \'Brillante\':"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "      // Circular facet layout"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "      return ("
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "        <g id=\"gem-brilliant\" className=\"animate-pulse\">"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          <circle cx=\"0\" cy=\"0\" r={half} fill={fillUrl} stroke={gemColor} strokeWidth=\"1\" />"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          {/* Facet lines */}"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          <line x1=\"0\" y1={-half} x2=\"0\" y2={half} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          <line x1={-half} y1=\"0\" x2={half} y2=\"0\" stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.8\" />"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          <line x1={-half * 0.7} y1={-half * 0.7} x2={half * 0.7} y2={half * 0.7} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          <line x1={-half * 0.7} y1={half * 0.7} x2={half * 0.7} y2={-half * 0.7} stroke={gemColor} strokeWidth=\"0.5\" strokeOpacity=\"0.6\" />"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
        lines {
          text: "          {/* Star table facet inside */}"
          type: UNIFIED_DIFF_LINE_TYPE_DELETE
        }
