    replacement_chunks {
      replacement_content: "/**\n * @license\n * SPDX-License-Identifier: Apache-2.0\n */\n\nimport React, { useState } from \'react\';\nimport { CollectionItem, JewelryType, CustomJewelryDesign } from \'../types\';\nimport { EXQUISITE_COLLECTION } from \'../data\';\nimport { ArrowRight, Compass, CompassIcon, Info, MessageSquare, RefreshCw, Sparkles, X } from \'lucide-react\';\nimport { motion, AnimatePresence } from \'motion/react\';\n\ninterface CollectionGridProps {\n  onLoadIntoCustomizer: (item: CustomJewelryDesign) => void;\n  onAskStylistAboutItem: (item: CollectionItem) => void;\n}\n\nconst CATEGORIES: { value: \'All\' | JewelryType; label: string }[] = [\n  { value: \'All\', label: \'Todo el Tesoro\' },\n  { value: \'Anillo\', label: \'Anillos Imperiales\' },\n  { value: \'Collar\', label: \'Collares de Gala\' },\n  { value: \'Pendientes\', label: \'Pendientes Celestiales\' },\n  { value: \'Brazalete\', label: \'Brazaletes Eternos\' },\n];\n\nexport default function CollectionGrid({ onLoadIntoCustomizer, onAskStylistAboutItem }: CollectionGridProps) {\n  const [activeFilter, setActiveFilter] = useState<\'All\' | JewelryType>(\'All\');\n  const [selectedItem, setSelectedItem] = useState<CollectionItem | null>(null);\n\n  const filteredItems = activeFilter === \'All\'\n    ? EXQUISITE_COLLECTION\n    : EXQUISITE_COLLECTION.filter(item => item.type === activeFilter);\n\n  const handleOpenDetails = (item: CollectionItem) => {\n    setSelectedItem(item);\n  };\n\n  const handleCloseDetails = () => {\n    setSelectedItem(null);\n  };\n\n  const handleCloneToCustomizer = (item: CollectionItem) => {\n    // Map collection item back to custom design model\n    const design: CustomJewelryDesign = {\n      type: item.type,\n      metal: item.metal,\n      gemstone: item.gemstone,\n      cut: item.cut || \'Brillante\',\n      carats: parseFloat(item.specs.weight.split(\' \')[0]) || 2.0,\n      engraving: \'\',\n    };\n    onLoadIntoCustomizer(design);\n    setSelectedItem(null);\n    \n    // Smooth scroll down to the customizer section\n    const element = document.getElementById(\'atelier-customizer\');\n    if (element) {\n      element.scrollIntoView({ behavior: \'smooth\', block: \'center\' });\n    }\n  };\n\n  return (\n    <div className=\"space-y-8\" id=\"imperial-collection\">\n      {/* Category filters */}\n      <div className=\"flex flex-wrap justify-center gap-2 max-w-2xl mx-auto\">\n        {CATEGORIES.map(cat => (\n          <button\n            key={cat.value}\n            onClick={() => setActiveFilter(cat.value)}\n            className={`px-4 py-2 rounded-full text-xs uppercase tracking-widest transition-all duration-300 font-mono border cursor-pointer ${\n              activeFilter === cat.value\n                ? \'bg-amber-500 text-black border-amber-500 font-semibold shadow-lg shadow-yellow-500/10\'\n                : \'bg-white/5 text-gray-400 border-white/5 hover:border-white/10 hover:text-white hover:bg-white/10\'\n            }`}\n          >\n            {cat.label}\n          </button>\n        ))}\n      </div>\n\n      {/* Grid */}\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n        <AnimatePresence mode=\"popLayout\">\n          {filteredItems.map((item, idx) => (\n            <motion.div\n              layout\n              initial={{ opacity: 0, y: 30 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, scale: 0.9 }}\n              transition={{ duration: 0.5, delay: idx * 0.05, ease: [0.16, 1, 0.3, 1] }}\n              key={item.id}\n              className=\"group bg-black/40 border border-white/10 rounded-2xl overflow-hidden hover:border-amber-500/30 transition-all duration-500 flex flex-col justify-between relative shadow-2xl hover:shadow-[0_15px_35px_rgba(251,191,36,0.05)]\"\n            >\n              {/* Product Visual Frame */}\n              <div className=\"relative overflow-hidden aspect-[4/3] bg-zinc-950\">\n                <img\n                  src={item.image}\n                  alt={item.name}\n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover transition-transform duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105\"\n                />\n                \n                {/* Floating Price Tag */}\n                <div className=\"absolute top-4 right-4 bg-black/80 backdrop-blur-md px-3 py-1.5 rounded-lg border border-amber-500/20\">\n                  <span className=\"text-amber-400 font-mono text-xs tracking-wider uppercase font-semibold\">\n                    {item.price}\n                  </span>\n                </div>\n\n                {/* Shimmering Overlay Glow on hover */}\n                <div className=\"absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60\" />\n              </div>\n\n              {/* Product Content Card */}\n              <div className=\"p-5 flex-1 flex flex-col justify-between space-y-4\">\n                <div className=\"space-y-2\">\n                  <div className=\"flex items-center justify-between\">\n                    <span className=\"text-[10px] tracking-widest font-mono text-amber-500 uppercase\">\n                      {item.type} \342\200\242 {item.metal}\n                    </span>\n                    <span className=\"text-[10px] text-gray-500 font-mono\">\n                      GIA Cert.\n                    </span>\n                  </div>\n                  \n                  <h3 className=\"text-lg font-light tracking-wide text-white group-hover:text-amber-400 transition-colors duration-300\">\n                    {item.name}\n                  </h3>\n                  \n                  <p className=\"text-xs text-gray-400 font-light leading-relaxed line-clamp-2\">\n                    {item.description}\n                  </p>\n                </div>\n\n                {/* Footer Action */}\n                <div className=\"pt-4 border-t border-white/5 flex justify-between items-center\">\n                  <div className=\"text-[10px] text-gray-500 uppercase tracking-widest font-mono\">\n                    Gema: <span className=\"text-gray-300\">{item.gemstone}</span>\n                  </div>\n                  \n                  <button\n                    onClick={() => handleOpenDetails(item)}\n                    className=\"text-xs text-amber-400 hover:text-amber-300 tracking-wider uppercase font-mono flex items-center gap-1.5 transition-colors duration-200 group-hover:translate-x-1\"\n                  >\n                    <span>Contemplar</span>\n                    <ArrowRight className=\"w-3.5 h-3.5\" />\n                  </button>\n                </div>\n              </div>\n            </motion.div>\n          ))}\n        </AnimatePresence>\n      </div>\n\n      {/* Cinematic Modal details */}\n      <AnimatePresence>\n        {selectedItem && (\n          <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4\">\n            {/* Dark Backdrop */}\n            <motion.div\n              initial={{ opacity: 0 }}\n              animate={{ opacity: 1 }}\n              exit={{ opacity: 0 }}\n              onClick={handleCloseDetails}\n              className=\"absolute inset-0 bg-black/85 backdrop-blur-md\"\n            />\n\n            {/* Modal Body */}\n            <motion.div\n              initial={{ opacity: 0, scale: 0.95, y: 30 }}\n              animate={{ opacity: 1, scale: 1, y: 0 }}\n              exit={{ opacity: 0, scale: 0.95, y: 30 }}\n              transition={{ duration: 0.4, ease: [0.16, 1, 0.3, 1] }}\n              className=\"bg-zinc-950 border border-amber-500/20 rounded-2xl overflow-hidden max-w-4xl w-full grid grid-cols-1 md:grid-cols-12 shadow-[0_0_50px_rgba(251,191,36,0.1)] relative text-white z-10\"\n            >\n              {/* Close Button */}\n              <button\n                onClick={handleCloseDetails}\n                className=\"absolute top-4 right-4 z-20 w-8 h-8 rounded-full bg-black/60 border border-white/10 flex items-center justify-center text-gray-400 hover:text-white transition-all cursor-pointer\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n\n              {/* Image Column */}\n              <div className=\"md:col-span-5 h-64 md:h-auto relative\">\n                <img\n                  src={selectedItem.image}\n                  alt={selectedItem.name}\n                  referrerPolicy=\"no-referrer\"\n                  className=\"w-full h-full object-cover\"\n                />\n                <div className=\"absolute inset-0 bg-gradient-to-t md:bg-gradient-to-r from-zinc-950 via-transparent to-transparent\" />\n                \n                {/* Visual Accent */}\n                <div className=\"absolute bottom-6 left-6\">\n                  <span className=\"text-[10px] uppercase font-mono tracking-widest text-amber-500 block mb-1\">Valor Comercial</span>\n                  <span className=\"text-2xl font-mono text-white font-bold\">{selectedItem.price}</span>\n                </div>\n              </div>\n\n              {/* Text / Stats Column */}\n              <div className=\"md:col-span-7 p-6 md:p-8 flex flex-col justify-between space-y-6\">\n                <div className=\"space-y-4\">\n                  <div>\n                    <span className=\"text-xs uppercase tracking-widest font-mono text-amber-500\">{selectedItem.type} de Alta Costura</span>\n                    <h2 className=\"text-2xl sm:text-3xl font-light tracking-wide text-white mt-1\">{selectedItem.name}</h2>\n                  </div>\n\n                  <p className=\"text-sm text-gray-300 font-light leading-relaxed\">\n                    {selectedItem.description}\n                  </p>\n\n                  {/* Poetic Narrative Story */}\n                  <div className=\"bg-amber-500/5 border border-amber-500/10 rounded-xl p-4 space-y-1\">\n                    <span className=\"text-[9px] uppercase tracking-widest font-mono text-amber-500 flex items-center gap-1.5\">\n                      <Compass className=\"w-3 h-3 text-amber-500\" />\n                      Historia de la Pieza\n                    </span>\n                    <p className=\"text-xs text-gray-400 font-light italic leading-relaxed\">\n                      &ldquo;{selectedItem.story}&rdquo;\n                    </p>\n                  </div>\n\n                  {/* Tech Specs Bento Grid */}\n                  <div className=\"grid grid-cols-3 gap-2 text-center pt-2\">\n                    <div className=\"bg-white/5 border border-white/5 rounded-lg p-2.5\">\n                      <span className=\"text-[9px] uppercase font-mono text-gray-500 block\">Masa Gemol\303\263gica</span>\n                      <span className=\"text-xs text-white font-mono font-bold block mt-1\">{selectedItem.specs.weight}</span>\n                    </div>\n                    <div className=\"bg-white/5 border border-white/5 rounded-lg p-2.5\">\n                      <span className=\"text-[9px] uppercase font-mono text-gray-500 block\">Pureza / Claridad</span>\n                      <span className=\"text-xs text-white font-mono font-bold block mt-1\">{selectedItem.specs.clarity || \'VVS Superior\'}</span>\n                    </div>\n                    <div className=\"bg-white/5 border border-white/5 rounded-lg p-2.5\">\n                      <span className=\"text-[9px] uppercase font-mono text-gray-500 block\">Origen Geogr\303\241fico</span>\n                      <span className=\"text-xs text-white font-mono font-bold block mt-1 truncate\" title={selectedItem.specs.origin}>{selectedItem.specs.origin?.split(\',\')[0]}</span>\n                    </div>\n                  </div>\n                </div>\n\n                {/* Action Row */}\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3 pt-4 border-t border-white/5\">\n                  <button\n                    onClick={() => handleCloneToCustomizer(selectedItem)}\n                    className=\"bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-white py-2.5 px-4 rounded-xl text-xs font-mono uppercase tracking-wider flex items-center justify-center gap-2 transition-all cursor-pointer\"\n                  >\n                    <RefreshCw className=\"w-3.5 h-3.5 text-amber-500\" />\n                    <span>Modificar en Atelier</span>\n                  </button>\n                  <button\n                    onClick={() => {\n                      onAskStylistAboutItem(selectedItem);\n                      handleCloseDetails();\n                    }}\n                    className=\"bg-amber-500 hover:bg-amber-400 text-black py-2.5 px-4 rounded-xl text-xs uppercase font-medium tracking-wider flex items-center justify-center gap-2 shadow-lg shadow-yellow-500/10 transition-all cursor-pointer\"\n                  >\n                    <MessageSquare className=\"w-3.5 h-3.5 fill-black text-black\" />\n                    <span>Consultar Estilo</span>\n                  </button>\n                </div>\n              </div>\n            </motion.div>\n          </div>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}\n"
    }
